  border-color: #ccc !important;
  background-color: #fff !important;
}
.product-form__input select:focus {
  border-color: #1a1a1a !important;
  outline: none !important;
  box-shadow: 0 0 0 3px rgba(26, 26, 26, 0.06) !important;
