{% if template.name == 'product' %}
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      var coll = document.getElementsByClassName("collapsible");
      for (var i = 0; i < coll.length; i++) {
        coll[i].addEventListener("click", function () {
          this.classList.toggle("active");
          var content = this.nextElementSibling;
          var icon = this.querySelector('.toggle-icon');
          if (content.style.display === "block") {
            content.style.display = "none";
            icon.textContent = "+";
          } else {
            content.style.display = "block";
            icon.textContent = "X";
          }
        });
      }

      // Initialize the first collapsible as open
      var firstCollapsible = document.querySelector('.collapsible');
      if (firstCollapsible) {
        firstCollapsible.classList.add('active');
        var firstContent = firstCollapsible.nextElementSibling;
        firstContent.style.display = "block";
        firstCollapsible.querySelector('.toggle-icon').textContent = "X";
      }
    });
  </script>
{% endif %}
    
  
