  <script>
    window.dataLayer = window.dataLayer || [];
    window.dlmAnalyticsContext = window.dlmAnalyticsContext || {};
    window.dlmAnalyticsContext.ga4_measurement_id = 'G-N4EQNK0MMB';
    window.dlmAnalyticsContext.site_language = (function (rawLocale) {
      var normalized = String(rawLocale || '').trim();
      if (!normalized) return 'en';
      return normalized.split(/[-_]/)[0].toLowerCase();
    })({{ request.locale.iso_code | json }});
    window.gtag = window.gtag || function () { window.dataLayer.push(arguments); };
    window.gtag('set', 'site_language', window.dlmAnalyticsContext.site_language);
    window.dataLayer.push({ site_language: window.dlmAnalyticsContext.site_language });
  </script>

