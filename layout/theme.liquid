    {% if template.name == 'product' %}
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      var coll = document.getElementsByClassName("collapsible");
      for (var i = 0; i < coll.length; i++) {
        coll[i].addEventListener("click", function () {
          this.classList.toggle("active");
          var content = this.nextElementSibling;
          var icon = this.querySelector('.toggle-icon');
          if (content.style.display === "block") {
            content.style.display = "none";
            icon.textContent = "+";
          } else {
            content.style.display = "block";
            icon.textContent = "X";
          }
        });
      }

      // Initialize the first collapsible as open
      var firstCollapsible = document.querySelector('.collapsible');
      if (firstCollapsible) {
        firstCollapsible.classList.add('active');
        var firstContent = firstCollapsible.nextElementSibling;
        firstContent.style.display = "block";
        firstCollapsible.querySelector('.toggle-icon').textContent = "X";
      }

      // Calculate delivery dates
      function formatDate(date) {
        const options = { month: 'short', day: 'numeric' };
        return date.toLocaleDateString('en-US', options);
      }

      function calculateDeliveryDates() {
        const today = new Date();

        const standardStart = new Date(today);
        standardStart.setDate(today.getDate() + 10); // 10 days from today
        const standardEnd = new Date(standardStart);
        standardEnd.setDate(standardStart.getDate() + 3); // 3 days range

        const expressStart = new Date(today);
        expressStart.setDate(today.getDate() + 7); // 7 days from today
        const expressEnd = new Date(expressStart);
        expressEnd.setDate(expressStart.getDate() + 3); // 3 days range

        document.getElementById('standard-delivery-range').textContent = `${formatDate(standardStart)}-${formatDate(standardEnd)}`;
        document.getElementById('express-delivery-range').textContent = `${formatDate(expressStart)}-${formatDate(expressEnd)}`;
      }

      calculateDeliveryDates();
    });
  </script>
{% endif %}
    
