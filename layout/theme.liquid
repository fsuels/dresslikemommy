  /* Critical Styles from component-slideshow.css */
  .slideshow {
    position: relative;
    overflow: hidden;
  }

  .slideshow__slide {
    display: none;
    position: absolute;
    width: 100%;
    height: 100%;
  }

  .slideshow__slide--active {
    display: block;
  }

  .slideshow__image {
    width: 100%;
    height: auto;
  }

  /* Critical Styles from section-collection-list.css */
  .collection-list {
    display: flex;
    flex-wrap: wrap;
    margin: 0 -1rem;
  }

  .collection-list__item {
    width: 50%;
    padding: 1rem;
    box-sizing: border-box;
  }

  @media (min-width: 750px) {
    .collection-list__item {
      width: 25%;
    }
  }

  /* Critical Styles from component-newsletter.css */
  .newsletter {
    padding: 2rem;
    background-color: var(--newsletter-bg-color, #f9f9f9);
    text-align: center;
  }

  .newsletter__title {
    font-size: 2rem;
    margin-bottom: 1rem;
  }

  .newsletter__form {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .newsletter__input {
    width: 100%;
    max-width: 400px;
    padding: 1rem;
    margin-bottom: 1rem;
  }

  .newsletter__button {
    padding: 1rem 2rem;
  }

  /* Critical Styles from component-list-social.css */
  .list-social {
    display: flex;
    justify-content: center;
    list-style: none;
    padding: 0;
    margin: 1rem 0;
  }

  .list-social__item {
    margin: 0 0.5rem;
  }

  .list-social__link {
    color: inherit;
    text-decoration: none;
    font-size: 1.5rem;
  }

  /* Critical Styles from component-list-payment.css */
  .list-payment {
    display: flex;
    justify-content: center;
    list-style: none;
    padding: 0;
    margin: 1rem 0;
  }

  .list-payment__item {
    margin: 0 0.5rem;
  }

  .list-payment__image {
    max-width: 50px;
    height: auto;
  }

  /* Critical Styles from template-collection.css */
  .collection-template {
    padding: 2rem 0;
  }

  .collection-template__header {
    text-align: center;
    margin-bottom: 2rem;
  }

  /* Critical Styles from mask-blobs.css */
  .mask-blob {
    clip-path: polygon(50% 0%, 61% 35%, 98% 35%, 68% 57%, 79% 91%, 50% 70%, 21% 91%, 32% 57%, 2% 35%, 39% 35%);
  }

  /* Critical Styles from quick-order-list.css */
  .quick-order-list {
    display: flex;
    flex-direction: column;
  }

  .quick-order-list__item {
    display: flex;
    justify-content: space-between;
    padding: 1rem 0;
  }

  /* Critical Styles from quantity-popover.css */
  .quantity-popover {
    position: absolute;
    background-color: #fff;
    border: 1px solid #ccc;
    padding: 1rem;
    z-index: 1000;
  }

  /* Critical Styles from component-volume-pricing.css */
  .volume-pricing {
    display: flex;
    flex-direction: column;
    margin-top: 1rem;
  }

  .volume-pricing__item {
    display: flex;
    justify-content: space-between;
    padding: 0.5rem 0;
  }

  /* Additional Critical Styles */
  /* Add any other critical styles needed to prevent layout shifts */
</style>

