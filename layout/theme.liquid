{%- comment -%}force-sync{%- endcomment -%}
<!doctype html>
<html class="js" lang="{{ request.locale.iso_code }}">
<head>
<link rel="stylesheet" href="{{ 'component-list-social.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-list-payment.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-rating.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'section-footer.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'mask-blobs.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-newsletter.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'quantity-popover.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-list-menu.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'quick-order-list.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'template-collection.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-volume-pricing.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-price.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-slider.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-card.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'section-collection-list.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-slideshow.css' | asset_url }}" media="print" onload="this.media='all'">
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="theme-color" content="">
  <link rel="canonical" href="{{ canonical_url }}">
 <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes">

  {% if template == 'product' %}
  {%- assign taxonomy_category1 = product.metafields.custom.category1 | default: '' | strip -%}
  {%- assign taxonomy_subcategory = product.metafields.custom.subcategory | default: '' | strip -%}
  {%- assign taxonomy_type = product.metafields.custom.type | default: product.type | default: '' | strip -%}
  {%- assign taxonomy_style = product.metafields.custom.style | default: '' | strip -%}
  {%- assign taxonomy_pattern = product.metafields.custom.pattern | default: '' | strip -%}
  {%- for tag in product.tags -%}
    {%- assign normalized_tag = tag | strip -%}
    {%- assign normalized_tag_downcase = normalized_tag | downcase -%}
    {%- if taxonomy_category1 == blank and normalized_tag_downcase contains 'category1:' -%}
      {%- assign taxonomy_category1 = normalized_tag | split: ':' | last | strip -%}
    {%- elsif taxonomy_category1 == blank and normalized_tag_downcase contains 'category:' -%}
      {%- assign taxonomy_category1 = normalized_tag | split: ':' | last | strip -%}
    {%- endif -%}
    {%- if taxonomy_subcategory == blank and normalized_tag_downcase contains 'subcategory:' -%}
      {%- assign taxonomy_subcategory = normalized_tag | split: ':' | last | strip -%}
    {%- endif -%}
    {%- if taxonomy_type == blank and normalized_tag_downcase contains 'type:' -%}
      {%- assign taxonomy_type = normalized_tag | split: ':' | last | strip -%}
    {%- endif -%}
    {%- if taxonomy_style == blank and normalized_tag_downcase contains 'style:' -%}
      {%- assign taxonomy_style = normalized_tag | split: ':' | last | strip -%}
    {%- endif -%}
    {%- if taxonomy_pattern == blank and normalized_tag_downcase contains 'pattern:' -%}
      {%- assign taxonomy_pattern = normalized_tag | split: ':' | last | strip -%}
    {%- endif -%}
  {%- endfor -%}
  {%- if taxonomy_category1 != blank -%}
  <meta name="custom-category1" content="{{ taxonomy_category1 | escape }}">
  {%- endif -%}
  {%- if taxonomy_subcategory != blank -%}
  <meta name="custom-subcategory" content="{{ taxonomy_subcategory | escape }}">
  {%- endif -%}
  {%- if taxonomy_type != blank -%}
  <meta name="custom-type" content="{{ taxonomy_type | escape }}">
  {%- endif -%}
  {%- if taxonomy_style != blank -%}
  <meta name="custom-style" content="{{ taxonomy_style | escape }}">
  {%- endif -%}
  {%- if taxonomy_pattern != blank -%}
  <meta name="custom-pattern" content="{{ taxonomy_pattern | escape }}">
  {%- endif -%}
  {% endif %}

  {%- liquid
    assign resolved_page_title = page_title
    if request.page_type == 'collection' and collection != blank and collection.handle == 'swimsuits'
      assign resolved_page_title = 'Swimsuits'
    endif
  -%}

  <!-- Title and Meta Description for SEO -->
  <title>
    {{ resolved_page_title }}
    {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
    {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
    {%- unless resolved_page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
  </title>
  {% if page_description %}
  <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  <!-- Other Meta Tags -->
  <meta name="theme-color" content="{{ settings.color_theme }}">
  <meta name="author" content="Your Store Name">

 <!-- Critical CSS -->
<style>
  /* Critical CSS Variables */
  :root {
    --alpha-button-background: 1;
    --alpha-button-border: 1;
    --alpha-link: 0.85;
    --alpha-badge-border: 0.1;
    /* Add any other variables needed */
  }

  /* Critical CSS Styles */

  /* Base Styles */
  .product-card-wrapper .card,
  .contains-card--product {
    --border-radius: var(--product-card-corner-radius);
    --border-width: var(--product-card-border-width);
    --border-opacity: var(--product-card-border-opacity);
    --shadow-horizontal-offset: var(--product-card-shadow-horizontal-offset);
    --shadow-vertical-offset: var(--product-card-shadow-vertical-offset);
    --shadow-blur-radius: var(--product-card-shadow-blur-radius);
    --shadow-opacity: var(--product-card-shadow-opacity);
    --shadow-visible: var(--product-card-shadow-visible);
    --image-padding: var(--product-card-image-padding);
    --text-alignment: var(--product-card-text-alignment);
  }

  .collection-card-wrapper .card,
  .contains-card--collection {
    --border-radius: var(--collection-card-corner-radius);
    --border-width: var(--collection-card-border-width);
    --border-opacity: var(--collection-card-border-opacity);
    --shadow-horizontal-offset: var(--collection-card-shadow-horizontal-offset);
    --shadow-vertical-offset: var(--collection-card-shadow-vertical-offset);
    --shadow-blur-radius: var(--collection-card-shadow-blur-radius);
    --shadow-opacity: var(--collection-card-shadow-opacity);
    --shadow-visible: var(--collection-card-shadow-visible);
    --image-padding: var(--collection-card-image-padding);
    --text-alignment: var(--collection-card-text-alignment);
  }

  .page-width {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .page-width-desktop {
    padding: 0;
    margin: 0 auto;
  }

  .utility-bar__grid.page-width {
    padding-left: 3rem;
    padding-right: 3rem;
  }

  .isolate {
    position: relative;
    z-index: 0;
  }

  .section + .section {
    margin-top: var(--spacing-sections-mobile);
  }

  .list-unstyled {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .hidden {
    display: none !important;
  }

  .visually-hidden {
    position: absolute !important;
    overflow: hidden;
    width: 1px;
    height: 1px;
    margin: -1px;
    padding: 0;
    border: 0;
    clip: rect(0 0 0 0);
    word-wrap: normal !important;
  }

  .visually-hidden--inline {
    margin: 0;
    height: 1em;
  }

  h1,
  h2,
  h3,
  .h1,
  .h2,
  .h5 {
    font-family: var(--font-heading-family);
    font-style: var(--font-heading-style);
    font-weight: var(--font-heading-weight);
    letter-spacing: calc(var(--font-heading-scale) * 0.06rem);
    color: rgb(var(--color-foreground));
    line-height: calc(1 + 0.3 / max(1, var(--font-heading-scale)));
    word-break: break-word;
  }

  h1,
  .h1 {
    font-size: calc(var(--font-heading-scale) * 3rem);
  }

  h2,
  .h2 {
    font-size: calc(var(--font-heading-scale) * 2rem);
  }

  h3 {
    font-size: calc(var(--font-heading-scale) * 1.7rem);
  }

  .h5 {
    font-size: calc(var(--font-heading-scale) * 1.2rem);
  }

  .caption {
    font-size: 1rem;
    letter-spacing: 0.07rem;
    line-height: calc(1 + 0.7 / var(--font-body-scale));
  }

  .caption-large,
  .field__input {
    font-size: 1.3rem;
    line-height: calc(1 + 0.5 / var(--font-body-scale));
    letter-spacing: 0.04rem;
  }

  @media screen and (max-width: 749px) {
    .small-hide {
      display: none !important;
    }
  }

  @media screen and (min-width: 750px) and (max-width: 989px) {
    .medium-hide {
      display: none !important;
    }
  }

  ul:empty,
  div:empty {
    display: none;
  }

  .link {
    display: inline-block;
    border: none;
    box-shadow: none;
    text-decoration: underline;
    text-underline-offset: 0.3rem;
    color: rgb(var(--color-link));
    background-color: transparent;
    font-size: 1.4rem;
    font-family: inherit;
  }

  .link--text {
    color: rgb(var(--color-foreground));
  }

  .full-unstyled-link {
    text-decoration: none;
    color: currentColor;
    display: block;
  }

  details > * {
    box-sizing: border-box;
  }

  .visibility-hidden {
    visibility: hidden;
  }

  @media (prefers-reduced-motion) {
    .motion-reduce {
      animation: none !important;
    }
  }

  :root {
    --duration-short: 0.1s;
    --duration-default: 0.2s;
    --duration-announcement-bar: 0.25s;
    --duration-medium: 0.3s;
    --duration-long: 0.5s;
    --duration-extra-long: 0.6s;
    --duration-extra-longer: 0.75s;
    --duration-extended: 3s;
    --ease-out-slow: cubic-bezier(0, 0, 0.3, 1);
    --animation-slide-in: slideIn var(--duration-extra-long) var(--ease-out-slow) forwards;
    --animation-fade-in: fadeIn var(--duration-extra-long) var(--ease-out-slow);
  }

  .inline-richtext a {
    text-underline-offset: 0.3rem;
    text-decoration-thickness: 0.1rem;
  }

  .inline-richtext a {
    color: currentColor;
  }

  .icon-arrow {
    width: 1.5rem;
  }

  h3 .icon-arrow {
    width: calc(var(--font-heading-scale) * 1.5rem);
  }

  .animate-arrow .icon-arrow path {
    transform: translate(-0.25rem);
  }

  summary {
    list-style: none;
    position: relative;
  }

  summary .icon-caret {
    position: absolute;
    height: 0.6rem;
    right: 1.5rem;
    top: calc(50% - 0.2rem);
  }

  summary::-webkit-details-marker {
    display: none;
  }

  .focus-none {
    box-shadow: none !important;
    outline: 0 !important;
  }

  .title,
  .title-wrapper-with-link {
    margin: 3rem 0 2rem;
  }

  .title-wrapper {
    margin-bottom: 3rem;
  }

  .title-wrapper-with-link {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 1rem;
    margin-bottom: 3rem;
    flex-wrap: wrap;
  }

  .title-wrapper--self-padded-tablet-down,
  .title-wrapper--self-padded-mobile {
    padding-left: 1.5rem;
    padding-right: 1.5rem;
  }

  .title-wrapper--no-top-margin {
    margin-top: 0;
  }

  .title-wrapper--no-top-margin > .title {
    margin-top: 0;
  }

  /* Critical Styles from component-card.css */
  /* ... (Existing styles from your code) ... */

  /* Critical Styles from component-slider.css */
  /* ... (Existing styles from your code) ... */

  /* Critical Styles from component-price.css */
  /* ... (Existing styles from your code) ... */

  /* Critical Styles from component-list-menu.css */
  /* ... (Existing styles from your code) ... */

  /* Critical Styles from component-slideshow.css */
  .slideshow {
    position: relative;
    overflow: hidden;
  }

  .slideshow__slide {
    display: none;
    position: absolute;
    width: 100%;
    height: 100%;
  }

  .slideshow__slide--active {
    display: block;
  }

  .slideshow__image {
    width: 100%;
    height: auto;
  }

  /* Critical Styles from section-collection-list.css */
  .collection-list {
    display: flex;
    flex-wrap: wrap;
    margin: 0 -1rem;
  }

  .collection-list__item {
    width: 50%;
    padding: 1rem;
    box-sizing: border-box;
  }

  @media (min-width: 750px) {
    .collection-list__item {
      width: 25%;
    }
  }

  /* Critical Styles from component-newsletter.css */
  .newsletter {
    padding: 2rem;
    background-color: var(--newsletter-bg-color, #f9f9f9);
    text-align: center;
  }

  .newsletter__title {
    font-size: 2rem;
    margin-bottom: 1rem;
  }

  .newsletter__form {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .newsletter__input {
    width: 100%;
    max-width: 400px;
    padding: 1rem;
    margin-bottom: 1rem;
  }

  .newsletter__button {
    padding: 1rem 2rem;
  }

  /* Critical Styles from component-list-social.css */
  .list-social {
    display: flex;
    justify-content: center;
    list-style: none;
    padding: 0;
    margin: 1rem 0;
  }

  .list-social__item {
    margin: 0 0.5rem;
  }

  .list-social__link {
    color: inherit;
    text-decoration: none;
    font-size: 1.5rem;
  }

  /* Critical Styles from component-list-payment.css */
  .list-payment {
    display: flex;
    justify-content: center;
    list-style: none;
    padding: 0;
    margin: 1rem 0;
  }

  .list-payment__item {
    margin: 0 0.5rem;
  }

  .list-payment__image {
    max-width: 50px;
    height: auto;
  }

  /* Critical Styles from template-collection.css */
  .collection-template {
    padding: 2rem 0;
  }

  .collection-template__header {
    text-align: center;
    margin-bottom: 2rem;
  }

  /* Critical Styles from mask-blobs.css */
  .mask-blob {
    clip-path: polygon(50% 0%, 61% 35%, 98% 35%, 68% 57%, 79% 91%, 50% 70%, 21% 91%, 32% 57%, 2% 35%, 39% 35%);
  }

  /* Critical Styles from quick-order-list.css */
  .quick-order-list {
    display: flex;
    flex-direction: column;
  }

  .quick-order-list__item {
    display: flex;
    justify-content: space-between;
    padding: 1rem 0;
  }

  /* Critical Styles from quantity-popover.css */
  .quantity-popover {
    position: absolute;
    background-color: #fff;
    border: 1px solid #ccc;
    padding: 1rem;
    z-index: 1000;
  }

  /* Critical Styles from component-volume-pricing.css */
  .volume-pricing {
    display: flex;
    flex-direction: column;
    margin-top: 1rem;
  }

  .volume-pricing__item {
    display: flex;
    justify-content: space-between;
    padding: 0.5rem 0;
  }

  /* Additional Critical Styles */
  /* Add any other critical styles needed to prevent layout shifts */
</style>

