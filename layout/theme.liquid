  <script>
    document.addEventListener('DOMContentLoaded', function () {
      var coll = document.getElementsByClassName("collapsible");
      for (var i = 0; i < coll.length; i++) {
        coll[i].addEventListener("click", function () {
          this.classList.toggle("active");
          var content = this.nextElementSibling;
          var icon = this.querySelector('.toggle-icon');
          var isExpanded = content.style.display === "block";
          if (isExpanded) {
            content.style.display = "none";
            icon.textContent = "+";
            this.setAttribute('aria-expanded', 'false');
          } else {
            content.style.display = "block";
            icon.textContent = "X";
            this.setAttribute('aria-expanded', 'true');
          }
        });
      }

      // Initialize the first collapsible as open
      var firstCollapsible = document.querySelector('.collapsible');
      if (firstCollapsible) {
        firstCollapsible.classList.add('active');
        var firstContent = firstCollapsible.nextElementSibling;
        firstContent.style.display = "block";
        firstCollapsible.querySelector('.toggle-icon').textContent = "X";
        firstCollapsible.setAttribute('aria-expanded', 'true');
      }

      // Calculate delivery dates
      function formatDate(date) {
        const options = { month: 'short', day: 'numeric' };
        return date.toLocaleDateString('en-US', options);
      }

      function calculateDeliveryDates() {
        const today = new Date();

        const standardStart = new Date(today);
        standardStart.setDate(today.getDate() + 10); // 10 days from today
        const standardEnd = new Date(standardStart);
        standardEnd.setDate(standardStart.getDate() + 3); // 3 days range

        const expressStart = new Date(today);
        expressStart.setDate(today.getDate() + 7); // 7 days from today
        const expressEnd = new Date(expressStart);
        expressEnd.setDate(expressStart.getDate() + 3); // 3 days range

        document.getElementById('standard-delivery-range').textContent = `${formatDate(standardStart)}-${formatDate(standardEnd)}`;
        document.getElementById('express-delivery-range').textContent = `${formatDate(expressStart)}-${formatDate(expressEnd)}`;
      }

      calculateDeliveryDates();
    });
  </script>
{% endif %}
    
<script>
  /**
   * DLM Size Policy (complete default)
   * Goal: dropdown label -> factory size token(s)
   * You can edit later, but this is complete enough to stop daily manual renaming.
   */
  window.DLM_SIZE_POLICY = {
    adult: {
      // Supports Mother/Father/Adult prefixes + common synonyms.
      // Dropdown like "Mother 2XL" will match factory "2XL" or "XXL".
      tokens: {
        "XS": ["XS"],
        "S": ["S"],
        "M": ["M"],
        "L": ["L"],
        "XL": ["XL"],
        "2XL": ["2XL", "XXL"],
        "3XL": ["3XL", "XXXL"],
        "4XL": ["4XL", "XXXXL"]
      }
    },

    /**
     * Numeric size conventions (common in China factories):
     * - Baby often: 59/66/73/80/90
     * - Kids often: 80/90/100/110/120/130/140/150/160/170
     *
     * IMPORTANT: These are DEFAULT mappings used only when your dropdown is age/month based.
     * If a supplier uses a different chart, the script will still try to match by "closest" logic,
     * but this default covers most cases and eliminates manual edits for typical factories.
     */
    babyMonthsToFactory: {
      // Single / range month labels you use -> likely factory numeric sizes
      "0-6":  "66",
      "3-6":  "66",
      "6":    "66",
      "6-9":  "73",
      "9":    "73",
      "9-12": "80",
      "12":   "80",
      "12-18":"90",
      "18":   "90",
      "18-24":"100"
    },

    childYearsToFactory: {
      // Child 1 Year -> 80 etc.
      "1": "80",
      "2": "90",
      "3": "100",
      "4": "110",
      "5": "120",
      "6": "130",
      "7": "140",
      "8": "140",
      "9": "150",
      "10":"150",
      "11":"160",
      "12":"160",
      "13":"170",
      "14":"170"
    },

    // T sizing: 2T->90, 3T->100, 4T->110 ... (common)
    tToFactory: {
      "2T":"90",
      "3T":"100",
      "4T":"110",
      "5T":"120",
      "6T":"130",
      "7T":"140",
      "8T":"150",
      "9T":"160",
      "10T":"170",
      "11T":"170",
      "12T":"170",
      "13T":"170",
      "14T":"170"
    }
  };
