  {{ content_for_header }}

  <script>
    (function () {
      var ctx = window.dlmAnalyticsContext || {};
      var measurementId = String(ctx.ga4_measurement_id || 'G-N4EQNK0MMB').trim();
      if (!measurementId) return;

      function hasAnyGtagScript() {
        return !!document.querySelector('script[src*="googletagmanager.com/gtag/js"]');
      }

      function hasShopifyAnalyticsRuntime() {
        return !!(window.ShopifyAnalytics || (window.Shopify && window.Shopify.analytics));
      }

      function hasConfigForMeasurement(id) {
        var layer = window.dataLayer || [];
        for (var i = 0; i < layer.length; i += 1) {
          var entry = layer[i];
          if (entry && typeof entry === 'object' && entry[0] === 'config' && entry[1] === id) {
            return true;
          }
        }
        return false;
      }

      if (!hasAnyGtagScript() && !hasShopifyAnalyticsRuntime()) {
        var gaScript = document.createElement('script');
        gaScript.async = true;
        gaScript.src = 'https://www.googletagmanager.com/gtag/js?id=' + encodeURIComponent(measurementId);
        document.head.appendChild(gaScript);
      }

      window.gtag = window.gtag || function () { window.dataLayer.push(arguments); };
      window.gtag('set', 'site_language', ctx.site_language || 'en');

      if (!hasConfigForMeasurement(measurementId)) {
        window.gtag('js', new Date());
        window.gtag('config', measurementId, {
          site_language: ctx.site_language || 'en',
          send_page_view: false,
        });
      }
    })();
  </script>

  {%- liquid
