{{ 'component-rte.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .size-fit-guide__heading {
    margin-bottom: 1rem;
    font-size: clamp(2rem, 3vw, 2.8rem);
  }

  .size-fit-guide__intro {
    margin-bottom: 2rem;
    color: var(--dlm-text-muted);
  }

  .size-fit-guide__tables {
    display: grid;
    gap: 2.5rem;
  }

  .size-fit-guide__table-note {
    margin-bottom: 0.75rem;
    color: var(--dlm-text-subtle);
  }

  .size-fit-guide__tables table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.95rem;
  }

  .size-fit-guide__tables th,
  .size-fit-guide__tables td {
    padding: 0.65rem 0.75rem;
    border: 1px solid rgba(var(--color-foreground), 0.15);
    text-align: left;
  }

  .size-fit-guide__tables th {
    background: rgba(var(--color-foreground), 0.05);
    font-weight: 600;
  }

  .size-fit-guide__tables caption {
    text-align: left;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .size-fit-guide__table-wrapper {
    overflow-x: auto;
  }

  .size-fit-guide__tips {
    margin-top: 1rem;
    padding: 1rem 1.25rem;
    border-left: 4px solid rgba(var(--color-foreground), 0.2);
    background: rgba(var(--color-foreground), 0.04);
    color: var(--dlm-text-muted);
  }

  .size-fit-guide__contact {
    margin-top: 2rem;
    font-weight: 600;
    color: var(--dlm-text-strong);
  }
{%- endstyle -%}

<section class="size-fit-guide section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <h1 class="size-fit-guide__heading">{{ section.settings.heading | escape }}</h1>
    {%- endif -%}

    {%- if section.settings.intro != blank -%}
      <div class="size-fit-guide__intro rte">{{ section.settings.intro }}</div>
    {%- endif -%}

    <div class="size-fit-guide__tables">
      <article class="size-fit-guide__table-block">
        <h2>Women&apos;s size chart</h2>
        <p class="size-fit-guide__table-note">Dual-sizing follows US measurements. If you prefer an oversized look, size up for more movement in the arms and skirt.</p>
        <div class="size-fit-guide__table-wrapper">
          <table>
            <caption>Women&apos;s dresses &amp; tops</caption>
            <thead>
              <tr>
                <th scope="col">Size</th>
                <th scope="col">US</th>
                <th scope="col">Bust (in)</th>
                <th scope="col">Waist (in)</th>
                <th scope="col">Hip (in)</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>XS</td>
                <td>0-2</td>
                <td>31-33</td>
                <td>24-26</td>
                <td>34-36</td>
              </tr>
              <tr>
                <td>S</td>
                <td>4-6</td>
                <td>33-35</td>
                <td>26-28</td>
                <td>36-38</td>
              </tr>
              <tr>
                <td>M</td>
                <td>8-10</td>
                <td>35-38</td>
                <td>28-31</td>
                <td>38-41</td>
              </tr>
              <tr>
                <td>L</td>
                <td>12-14</td>
                <td>38-41</td>
                <td>31-34</td>
                <td>41-44</td>
              </tr>
              <tr>
                <td>XL</td>
                <td>16-18</td>
                <td>41-45</td>
                <td>34-38</td>
                <td>44-48</td>
              </tr>
            </tbody>
          </table>
        </div>
      </article>

      <article class="size-fit-guide__table-block">
        <h2>Men&apos;s size chart</h2>
        <p class="size-fit-guide__table-note">Men&apos;s shirts are designed for a modern, tailored look. Size up if you prefer additional room through the shoulders.</p>
        <div class="size-fit-guide__table-wrapper">
          <table>
            <caption>Men&apos;s shirts</caption>
            <thead>
              <tr>
                <th scope="col">Size</th>
                <th scope="col">Chest (in)</th>
                <th scope="col">Waist (in)</th>
                <th scope="col">Neck (in)</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>S</td>
                <td>35-37</td>
                <td>28-30</td>
                <td>14-14.5</td>
              </tr>
              <tr>
                <td>M</td>
                <td>38-40</td>
                <td>31-33</td>
                <td>15-15.5</td>
              </tr>
              <tr>
                <td>L</td>
                <td>41-44</td>
                <td>34-37</td>
                <td>16-16.5</td>
              </tr>
              <tr>
                <td>XL</td>
                <td>45-48</td>
                <td>38-41</td>
                <td>17-17.5</td>
              </tr>
            </tbody>
          </table>
        </div>
      </article>

      <article class="size-fit-guide__table-block">
        <h2>Kids&apos; size chart</h2>
        <p class="size-fit-guide__table-note">Choose the size that aligns with current height. When in doubt, size up to accommodate a mid-season growth spurt.</p>
        <div class="size-fit-guide__table-wrapper">
          <table>
            <caption>Kids (girls &amp; boys)</caption>
            <thead>
              <tr>
                <th scope="col">Size</th>
                <th scope="col">Approx. age</th>
                <th scope="col">Height (in)</th>
                <th scope="col">Weight (lbs)</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>2T</td>
                <td>1.5-2 yrs</td>
                <td>33-36</td>
                <td>26-29</td>
              </tr>
              <tr>
                <td>3T</td>
                <td>2-3 yrs</td>
                <td>36-39</td>
                <td>28-33</td>
              </tr>
              <tr>
                <td>4-5</td>
                <td>4-5 yrs</td>
                <td>40-44</td>
                <td>34-42</td>
              </tr>
              <tr>
                <td>6-7</td>
                <td>6-7 yrs</td>
                <td>45-49</td>
                <td>43-55</td>
              </tr>
              <tr>
                <td>8-10</td>
                <td>8-10 yrs</td>
                <td>50-56</td>
                <td>56-75</td>
              </tr>
            </tbody>
          </table>
        </div>
      </article>

      <article class="size-fit-guide__table-block">
        <h2>Baby size chart</h2>
        <p class="size-fit-guide__table-note">Baby rompers and bodysuits include extra stretch through the torso for comfort when seated.</p>
        <div class="size-fit-guide__table-wrapper">
          <table>
            <caption>Baby (newborn to 24 months)</caption>
            <thead>
              <tr>
                <th scope="col">Size</th>
                <th scope="col">Age</th>
                <th scope="col">Height (in)</th>
                <th scope="col">Weight (lbs)</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>NB</td>
                <td>0-3 mo</td>
                <td>18-23</td>
                <td>7-12</td>
              </tr>
              <tr>
                <td>3M</td>
                <td>3-6 mo</td>
                <td>23-26</td>
                <td>12-16</td>
              </tr>
              <tr>
                <td>6-9M</td>
                <td>6-9 mo</td>
                <td>26-28</td>
                <td>16-20</td>
              </tr>
              <tr>
                <td>12M</td>
                <td>9-12 mo</td>
                <td>28-30</td>
                <td>20-24</td>
              </tr>
              <tr>
                <td>18-24M</td>
                <td>18-24 mo</td>
                <td>30-34</td>
                <td>24-29</td>
              </tr>
            </tbody>
          </table>
        </div>
      </article>
    </div>

    {%- if section.settings.fit_tips != blank -%}
      <div class="size-fit-guide__tips rte">
        {{ section.settings.fit_tips }}
      </div>
    {%- endif -%}

    {%- if section.settings.contact_text != blank or section.settings.contact_email != blank -%}
      <p class="size-fit-guide__contact">
        {{ section.settings.contact_text }}
        {%- if section.settings.contact_email != blank -%}
          <a href="mailto:{{ section.settings.contact_email }}">{{ section.settings.contact_email }}</a>
        {%- endif -%}
      </p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Size & fit guide",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Size & Fit Guide"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Intro",
      "default": "<p>Use the charts below to find the best fit for every family member. Measurements are listed in inches and follow US sizing standards.</p>"
    },
    {
      "type": "richtext",
      "id": "fit_tips",
      "label": "Fit tips",
      "default": "<p><strong>Fit tip:</strong> Between sizes? Size up for growing kids and down for women&apos;s fitted silhouettes. Our concierge team can help you mix and match across genders.</p>"
    },
    {
      "type": "text",
      "id": "contact_text",
      "label": "Contact text",
      "default": "Still unsure about sizing? Email"
    },
    {
      "type": "text",
      "id": "contact_email",
      "label": "Contact email",
      "default": "support@dresslikemommy.com"
    }
  ],
  "presets": [
    {
      "name": "Size & fit guide"
    }
  ]
}
{% endschema %}
