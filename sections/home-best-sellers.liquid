{{ 'component-slider.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .best-sellers-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .best-sellers-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .best-sellers__heading {
    margin-bottom: 0.25rem;
  }

  .best-sellers__subheading {
    margin-top: 0;
    margin-bottom: 2rem;
    color: rgba(var(--color-foreground), 0.75);
    max-width: 520px;
  }

  .best-sellers__grid {
    display: grid;
    gap: 1.5rem;
  }

  @media screen and (min-width: 990px) {
    .best-sellers__grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  .best-sellers__card {
    display: flex;
    flex-direction: column;
    height: 100%;
    background: #fff;
    border-radius: 22px;
    padding: 1.25rem;
    box-shadow: 0 25px 50px rgba(0, 0, 0, 0.08);
  }

  .best-sellers__card-media {
    margin-bottom: 1rem;
  }

  .best-sellers__card-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.9rem;
    color: rgba(var(--color-foreground), 0.7);
    margin-bottom: 0.75rem;
  }

  .best-sellers__pill {
    border: 1px solid rgba(var(--color-foreground), 0.15);
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    font-size: 0.8rem;
  }

  .best-sellers__cta {
    margin-top: 1rem;
    text-align: right;
  }

  .best-sellers__cta-link {
    font-weight: 600;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
  }

  .best-sellers__cta-link svg {
    width: 16px;
    height: 16px;
  }

  @media screen and (max-width: 989px) {
    .best-sellers__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 749px) {
    .best-sellers__grid {
      grid-template-columns: 1fr;
    }
  }
{%- endstyle -%}

{%- assign products = section.settings.collection.products | default: section.settings.fallback_products -%}

<section class="color-{{ section.settings.color_scheme }} gradient best-sellers-{{ section.id }}">
  <div class="page-width">
    <div class="title-wrapper-with-link title-wrapper--self-padded-mobile">
      <div>
        <h2 class="best-sellers__heading {{ section.settings.heading_size }}">{{ section.settings.heading }}</h2>
        {% if section.settings.subheading != blank %}
          <p class="best-sellers__subheading">{{ section.settings.subheading }}</p>
        {% endif %}
      </div>
      {% if section.settings.view_all_link != blank %}
        <a href="{{ section.settings.view_all_link }}" class="link underlined-link" data-cta-id="best_sellers_view_all">
          {{ section.settings.view_all_label }}
        </a>
      {% endif %}
    </div>

    <div class="best-sellers__grid">
      {%- for block in section.blocks -%}
        {%- assign product = block.settings.product -%}
        {%- if product == blank -%}
          {%- continue -%}
        {%- endif -%}

        <div class="best-sellers__card" {{ block.shopify_attributes }}>
          <div class="best-sellers__card-media">
            {% render 'card-product',
              card_product: product,
              media_aspect_ratio: 'square',
              show_rating: true,
              section_id: section.id,
              show_secondary_image: true,
              image_ratio: 'square'
            %}
          </div>
          <div class="best-sellers__card-meta">
            <span class="best-sellers__pill">
              {% if block.settings.badge != blank %}
                {{ block.settings.badge }}
              {% else %}
                {{ 'sections.featured_collection.shop_now' | t }}
              {% endif %}
            </span>
            <span>{{ product.vendor | default: shop.name }}</span>
          </div>
          <div>
            <p class="rte">{{ block.settings.description }}</p>
            <div class="best-sellers__cta">
              <a
                href="{{ product.url }}"
                class="best-sellers__cta-link"
                data-cta-id="best_sellers_product"
                data-cta-scope="best_sellers"
                data-product-handle="{{ product.handle }}"
              >
                {{ block.settings.cta_label }}
                {% render 'icon-arrow' %}
              </a>
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Home best sellers",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Fallback collection (if blocks empty)"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Family favorites this week"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Coordinated outfits shoppers can’t stop adding to cart."
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h2", "label": "Medium" },
        { "value": "h1", "label": "Large" }
      ],
      "default": "h2"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View all link"
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View all label",
      "default": "Shop all best sellers"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge text",
          "default": "Trending"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Short description",
          "default": "Matching set loved for comfy fabrics and photo-ready prints."
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "CTA label",
          "default": "View set"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Home best sellers",
      "blocks": [
        { "type": "product" },
        { "type": "product" },
        { "type": "product" },
        { "type": "product" }
      ]
    }
  ]
}
{% endschema %}
