{{ 'component-slider.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign featured_collection = section.settings.collection
  if featured_collection == blank
    assign featured_collection = collections['family-favorites']
  endif

  assign has_products = false
  if featured_collection and featured_collection.all_products_count > 0
    assign has_products = true
  endif

  assign fallback_collection = collections['family-sets']
  assign use_fallback = false

  assign product_limit = section.settings.products_to_show | default: 8
  assign columns_desktop = section.settings.products_per_row | default: 4

  if has_products
    assign display_collection = featured_collection
  elsif request.design_mode == false and fallback_collection and fallback_collection.all_products_count > 0
    assign use_fallback = true
    assign display_collection = fallback_collection
    assign has_products = true
    assign product_limit = 4
  endif

  unless display_collection
    assign display_collection = featured_collection
  endunless

  assign render_section = has_products or request.design_mode
-%}

{%- style -%}
  .family-faves-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .family-faves-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .family-faves__heading {
    margin-bottom: 0.25rem;
  }

  .family-faves__subheading {
    margin: 0 0 1.5rem;
    color: var(--dlm-text-muted);
    max-width: 560px;
  }

  .family-faves__card-wrapper {
    position: relative;
  }

  .family-faves__badge {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    z-index: 2;
    padding: 0.15rem 0.65rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border-radius: 999px;
    background: rgba(var(--color-background), 0.9);
    color: rgba(var(--color-foreground), 0.95);
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.12);
  }

  .family-faves__empty {
    text-align: center;
    padding: 2rem;
    border: 1px dashed rgba(var(--color-foreground), 0.2);
    border-radius: 16px;
  }

  .family-faves__slider-buttons {
    margin-top: 1rem;
    display: flex;
    justify-content: flex-end;
    gap: 0.5rem;
  }

  .family-faves__fallback-note {
    margin: 0.5rem 0 0;
    font-size: 0.9rem;
    color: var(--dlm-text-subtle);
  }
{%- endstyle -%}

{% if render_section %}
<section class="color-{{ section.settings.color_scheme }} gradient family-faves-{{ section.id }}">
  <div class="page-width">
    <div class="title-wrapper-with-link title-wrapper--self-padded-mobile">
      <div>
        <h2 class="family-faves__heading section-heading {{ section.settings.heading_size }}">{{ section.settings.heading }}</h2>
        {% if section.settings.subheading != blank %}
          <p class="family-faves__subheading">{{ section.settings.subheading }}</p>
        {% endif %}
        {% if use_fallback %}
          <p class="family-faves__fallback-note">Showing top-rated matching sets while Family Favorites updates.</p>
        {% endif %}
      </div>
      {% if section.settings.view_all_link != blank %}
        <a href="{{ section.settings.view_all_link }}" class="link underlined-link" data-cta-id="family_faves_view_all">
          {{ section.settings.view_all_label }}
        </a>
      {% endif %}
    </div>

    {% if has_products %}
      <slider-component class="slider-mobile-gutter">
        <ul
          id="Slider-{{ section.id }}"
          class="contains-card contains-card--product grid grid--{{ columns_desktop }}-col-desktop grid--2-col-tablet-down slider slider--tablet"
          role="list"
        >
          {%- for product in display_collection.products limit: product_limit -%}
            {%- assign highlight_badge = '' -%}
            {%- for tag in product.tags -%}
              {%- assign tag_downcase = tag | downcase -%}
              {%- if tag_downcase == 'bestseller' or tag_downcase == 'best seller' -%}
                {%- assign highlight_badge = 'Bestseller' -%}
                {%- break -%}
              {%- elsif tag_downcase == 'new' -%}
                {%- assign highlight_badge = 'New' -%}
                {%- break -%}
              {%- elsif tag_downcase == 'limited' or tag_downcase == 'limited edition' -%}
                {%- assign highlight_badge = 'Limited' -%}
                {%- break -%}
              {%- endif -%}
            {%- endfor -%}

            <li id="Slide-{{ section.id }}-{{ forloop.index }}" class="slider__slide">
              <div class="family-faves__card-wrapper">
                {% if highlight_badge != blank %}
                  <span class="family-faves__badge">{{ highlight_badge }}</span>
                {% endif %}

                {% render 'card-product',
                  card_product: product,
                  media_aspect_ratio: section.settings.image_ratio,
                  show_secondary_image: true,
                  show_rating: true,
                  quick_add: true,
                  section_id: section.id
                %}
              </div>
            </li>
          {%- endfor -%}
        </ul>
        <div class="slider-buttons family-faves__slider-buttons">
          <button type="button" class="slider-button slider-button--prev" name="previous" aria-label="{{ 'general.slider.previous_slide' | t }}">
            {% render 'icon-caret' %}
          </button>
          <button type="button" class="slider-button slider-button--next" name="next" aria-label="{{ 'general.slider.next_slide' | t }}">
            {% render 'icon-caret' %}
          </button>
        </div>
      </slider-component>
    {% elsif request.design_mode %}
      <div class="family-faves__empty">
        {{ 'sections.home_best_sellers.empty_state' | t | default: 'Assign the Family Favorites collection to populate this carousel.' }}
      </div>
    {% endif %}
  </div>
</section>
{% endif %}

{% schema %}
{
  "name": "Home best sellers",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Family favorites collection",
      "info": "Uses the Family Favorites collection if left blank."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Family favorites right now"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Coordinated outfits families keep reviewing 5 stars."
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h2", "label": "Medium" },
        { "value": "h1", "label": "Large" }
      ],
      "default": "h2"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View all link"
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View all label",
      "default": "Shop all favorites"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 8,
      "max": 12,
      "step": 1,
      "label": "Products to show",
      "default": 8
    },
    {
      "type": "range",
      "id": "products_per_row",
      "min": 3,
      "max": 5,
      "step": 1,
      "label": "Desktop columns",
      "default": 4
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [
        { "value": "square", "label": "Square" },
        { "value": "portrait", "label": "Portrait" },
        { "value": "adapt", "label": "Adapt" }
      ],
      "default": "square"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Home best sellers"
    }
  ]
}
{% endschema %}
