{% liquid
  assign color = section.settings.color_scheme
  assign heading = section.settings.heading | default: 'Shipping & Delivery'
  assign body = section.settings.body
  assign list_heading = section.settings.list_heading | default: 'Typical transit windows'
  assign estimate_label = section.settings.estimate_label | default: 'Delivery estimate'
%}

<section class="shipping-faq color-{{ color }} gradient">
  <div class="page-width section-{{ section.id }}-padding">
    <div class="shipping-faq__intro">
      <h2>{{ heading }}</h2>
      {% if body != blank %}
        <div class="rte">{{ body }}</div>
      {% endif %}
    </div>

    <div class="shipping-faq__estimate">
      {% render 'shipping-estimate-inline', context: 'shipping-faq', label: estimate_label %}
    </div>

    <div class="shipping-faq__regions">
      <h3>{{ list_heading }}</h3>
      {% render 'shipping-promise-list' %}
    </div>

    {% if section.blocks.size > 0 %}
      <div class="shipping-faq__accordion">
        {% for block in section.blocks %}
          <details class="shipping-faq__item" {{ block.shopify_attributes }}>
            <summary>
              <span>{{ block.settings.question | default: 'Question' }}</span>
              {% render 'icon-caret' %}
            </summary>
            <div class="shipping-faq__answer">
              <div class="rte">{{ block.settings.answer }}</div>
            </div>
          </details>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Shipping FAQ",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shipping & delivery"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Intro text",
      "default": "<p>We keep one shipping promise across every page. Processing takes 2–3 business days, then parcels hand off to trusted carriers with the timelines below.</p>"
    },
    {
      "type": "text",
      "id": "estimate_label",
      "label": "Estimate label",
      "default": "Delivery estimate"
    },
    {
      "type": "text",
      "id": "list_heading",
      "label": "Region list heading",
      "default": "Transit windows by destination"
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Do you support expedited shipping?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Express service unlocks automatically once a parcel clears processing. Use the tracking email to switch carriers or update delivery preferences.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shipping FAQ",
      "blocks": [
        {
          "type": "faq"
        },
        {
          "type": "faq"
        }
      ]
    }
  ]
}
{% endschema %}
