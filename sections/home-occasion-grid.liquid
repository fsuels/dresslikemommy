{% style %}
  .home-occasion-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .home-occasion-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .home-occasion__grid {
    display: grid;
    gap: 1.25rem;
  }

  @media screen and (min-width: 990px) {
    .home-occasion__grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  .home-occasion__card {
    border-radius: 22px;
    padding: 1.25rem;
    background: rgba(var(--color-background), 1);
    box-shadow: 0 20px 45px rgba(0, 0, 0, 0.08);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    text-decoration: none;
  }
{% endstyle %}

<section class="home-occasion-{{ section.id }} color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width">
    <div class="title-wrapper-with-link">
      <div>
        <h2 class="{{ section.settings.heading_size }}">{{ section.settings.heading }}</h2>
        {% if section.settings.subheading != blank %}
          <p class="home-reassurance__subheading">{{ section.settings.subheading }}</p>
        {% endif %}
      </div>
    </div>

    <div class="home-occasion__grid">
      {% for block in section.blocks %}
        <a href="{{ block.settings.link }}" class="home-occasion__card" {{ block.shopify_attributes }} data-cta-id="occasion_card" data-cta-scope="occasions">
          <span class="home-outfits__tag">{{ block.settings.tagline }}</span>
          <h3>{{ block.settings.title }}</h3>
          <p class="rte">{{ block.settings.description }}</p>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Home match by occasion",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Match by occasion"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Curated outfits for every calendar moment."
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h2", "label": "Medium" },
        { "value": "h1", "label": "Large" }
      ],
      "default": "h2"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "occasion",
      "name": "Occasion",
      "settings": [
        {
          "type": "text",
          "id": "tagline",
          "label": "Tagline",
          "default": "Weekend"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Brunch matching"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Soft pastels and breezy fabrics perfect for daytime plans."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Home match by occasion",
      "blocks": [
        { "type": "occasion" },
        { "type": "occasion" },
        { "type": "occasion" },
        { "type": "occasion" }
      ]
    }
  ]
}
{% endschema %}
