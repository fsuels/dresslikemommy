{%- comment -%}
  Three-column reassurance row for key benefits.
{%- endcomment -%}

{{ 'component-slider.css' | asset_url | stylesheet_tag }}
{{ 'component-rating.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .home-reassurance-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .home-reassurance-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .home-reassurance__grid {
    display: grid;
    gap: 1.5rem;
  }

  @media screen and (min-width: 990px) {
    .home-reassurance__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .home-reassurance__card {
    border-radius: 24px;
    padding: 1.75rem;
    background: rgba(var(--color-background), 1);
    box-shadow: 0 20px 45px rgba(0, 0, 0, 0.08);
    height: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .home-reassurance__heading {
    margin-bottom: 0.5rem;
  }

  .home-reassurance__subheading {
    margin-top: 0;
    margin-bottom: 2rem;
    color: var(--dlm-text-muted);
    max-width: 520px;
  }

  .home-reassurance__icon {
    width: 40px;
    height: 40px;
    border-radius: 12px;
    background: rgba(var(--color-foreground), 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .home-reassurance__rating-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
  }

  .home-reassurance__rating-row .rating {
    --star-size: 1rem;
  }

  .home-reassurance__rating-link {
    font-weight: 600;
    display: inline-flex;
    gap: 0.35rem;
    align-items: center;
    margin-top: 0.25rem;
  }

  .home-reassurance__rating-note {
    font-size: 0.9rem;
    color: rgba(var(--color-foreground), 0.75);
    margin-top: 0.35rem;
  }

  .home-reassurance__ugc {
    margin-top: 2rem;
  }

  .home-reassurance__ugc-heading {
    margin-bottom: 0.75rem;
    font-size: 1rem;
    font-weight: 600;
    color: rgba(var(--color-foreground), 0.75);
  }

  .home-reassurance__snippets {
    margin-top: 2rem;
    border-radius: 20px;
    background: rgba(var(--color-background), 0.85);
    border: 1px solid rgba(var(--color-foreground), 0.1);
    padding: 1.25rem;
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .home-reassurance__snippet {
    flex: 1 1 calc(25% - 1rem);
    min-width: 220px;
    border-radius: 14px;
    background: rgba(var(--color-background), 1);
    padding: 1rem;
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.06);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .home-reassurance__snippet-rating {
    font-weight: 700;
    color: rgba(var(--color-foreground), 0.85);
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.95rem;
  }

  .home-reassurance__snippet-quote {
    margin: 0;
    font-size: 0.95rem;
    color: rgba(var(--color-foreground), 0.9);
  }

  .home-reassurance__snippet-meta {
    font-size: 0.85rem;
    color: rgba(var(--color-foreground), 0.65);
    font-weight: 600;
  }

  .home-reassurance__ugc-rail {
    border-radius: 18px;
    background: rgba(var(--color-background), 0.6);
    padding: 1rem;
  }

  .home-reassurance__ugc-list {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(120px, 160px);
    gap: 0.75rem;
  }

  .home-reassurance__ugc-list .slider__slide {
    width: auto;
  }

  .home-reassurance__ugc-link {
    display: block;
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
  }

  .home-reassurance__ugc-link img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .home-reassurance__ugc-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding: 0.75rem;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0) 20%, rgba(0, 0, 0, 0.55) 100%);
    opacity: 0;
    transition: opacity var(--duration-short) ease;
  }

  .home-reassurance__ugc-link:hover .home-reassurance__ugc-overlay,
  .home-reassurance__ugc-link:focus-visible .home-reassurance__ugc-overlay {
    opacity: 1;
  }

  .home-reassurance__ugc-overlay span {
    color: #fff;
    font-weight: 600;
    font-size: 0.9rem;
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
    background: rgba(0, 0, 0, 0.55);
  }

  @media screen and (max-width: 749px) {
    .home-reassurance__snippets {
      flex-direction: column;
    }

    .home-reassurance__snippet {
      min-width: auto;
    }
  }
{%- endstyle -%}

<section class="color-{{ section.settings.color_scheme }} gradient home-reassurance-{{ section.id }} section-band section-band--muted">
  <div class="page-width">
    {% if section.settings.heading != blank %}
      <div class="title-wrapper-with-link">
        <div>
          <h2 class="home-reassurance__heading section-heading {{ section.settings.heading_size }}">{{ section.settings.heading }}</h2>
          {% if section.settings.subheading != blank %}
            <p class="home-reassurance__subheading">{{ section.settings.subheading }}</p>
          {% endif %}
        </div>
      </div>
    {% endif %}

    <div class="home-reassurance__grid">
      {%- for block in section.blocks -%}
        <article class="home-reassurance__card" {{ block.shopify_attributes }}>
          {% if block.settings.icon != 'none' %}
            <div class="home-reassurance__icon">
              {% case block.settings.icon %}
                {% when 'truck' %}{% render 'icon-delivery-truck' %}
                {% when 'star' %}{% render 'icon-star' %}
                {% when 'exchange' %}{% render 'icon-refresh' %}
              {% endcase %}
            </div>
          {% endif %}
          <h3 class="{{ section.settings.card_heading_size }}">{{ block.settings.title }}</h3>

          {%- if block.settings.enable_reviews_row -%}
            {%- liquid
              assign rating_value = block.settings.reviews_rating | default: 4.8
              assign rating_value_number = rating_value | plus: 0
              assign rating_max = block.settings.reviews_scale | default: 5
              assign rating_count = block.settings.reviews_count | default: '30k+'
              assign reviews_link_label = block.settings.reviews_link_label | default: 'Read customer reviews'
              assign rating_decimal = 0
              assign decimal = rating_value_number | modulo: 1
              if decimal >= 0.3 and decimal <= 0.7
                assign rating_decimal = 0.5
              elsif decimal > 0.7
                assign rating_decimal = 1
              endif
            -%}
            <div class="home-reassurance__rating-row">
              <div
                class="rating"
                role="img"
                aria-label="{{ 'accessibility.star_reviews_info' | t: rating_value: rating_value, rating_max: rating_max }}"
              >
                <span
                  aria-hidden="true"
                  class="rating-star"
                  style="--rating: {{ rating_value_number | floor }}; --rating-max: {{ rating_max }}; --rating-decimal: {{ rating_decimal }};"
                ></span>
              </div>
              <span class="caption-large">{{ rating_value }}/{{ rating_max }}</span>
              <span class="rating-count caption">({{ rating_count }})</span>
            </div>
            {%- if block.settings.reviews_link != blank -%}
              <a
                href="{{ block.settings.reviews_link }}"
                class="link underlined-link home-reassurance__rating-link link--cta-block"
                data-cta-id="reassurance_reviews"
              >
                {{ reviews_link_label }}
              </a>
            {%- endif -%}
            <p class="home-reassurance__rating-note">
              {{ block.settings.rating_note | default: 'Colors and fits are tested for real family photoshoots.' }}
            </p>
          {%- else -%}
            <p class="rte">{{ block.settings.description }}</p>
          {%- endif -%}

          {% if block.settings.cta_label != blank and block.settings.cta_link != blank %}
            <div>
              <a
                href="{{ block.settings.cta_link }}"
                class="link underlined-link link--cta-block"
                data-cta-id="reassurance_cta"
                data-cta-scope="reassurance"
                data-reassurance-title="{{ block.settings.title | escape }}"
              >
                {{ block.settings.cta_label }}
              </a>
            </div>
          {% endif %}
        </article>
      {%- endfor -%}
    </div>

    {%- assign snippet_raw = section.settings.review_snippets | split: '\n' -%}
    {%- assign snippet_count = 0 -%}
    {%- assign snippets_exist = false -%}
    {%- for snippet_line in snippet_raw -%}
      {%- assign clean_line = snippet_line | strip -%}
      {%- if clean_line != blank -%}
        {%- assign snippets_exist = true -%}
        {%- break -%}
      {%- endif -%}
    {%- endfor -%}

    {%- if snippets_exist -%}
      {%- if section.settings.review_snippets_heading != blank -%}
        <p class="home-reassurance__ugc-heading">{{ section.settings.review_snippets_heading }}</p>
      {%- endif -%}
      <div class="home-reassurance__snippets">
        {%- for snippet_line in snippet_raw -%}
          {%- assign clean_line = snippet_line | strip -%}
          {%- if clean_line == blank -%}{%- continue -%}{%- endif -%}
          {%- if snippet_count >= 13 -%}{%- break -%}{%- endif -%}
          {%- assign parts = clean_line | split: '|' -%}
          {%- assign rating_value = parts[0] | default: '5.0' -%}
          {%- assign quote_text = parts[1] | default: 'Loved the fit and fabric.' -%}
          {%- assign meta_text = parts[2] | default: 'Verified buyer' -%}
          {%- assign snippet_count = snippet_count | plus: 1 -%}
          <article class="home-reassurance__snippet" aria-label="Rated {{ rating_value }} out of 5: {{ quote_text | strip }}">
            <div class="home-reassurance__snippet-rating">
              {% render 'icon-star' %}
              <span>{{ rating_value }}</span>
            </div>
            <p class="home-reassurance__snippet-quote">“{{ quote_text | strip }}”</p>
            <span class="home-reassurance__snippet-meta">{{ meta_text | strip }}</span>
          </article>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.ugc_collection != blank -%}
      {%- assign ugc_limit = section.settings.ugc_photo_limit | default: 6 -%}
      {%- assign ugc_rendered = 0 -%}
      <div class="home-reassurance__ugc">
        {% if section.settings.ugc_heading != blank %}
          <p class="home-reassurance__ugc-heading">{{ section.settings.ugc_heading }}</p>
        {% endif %}
        <div class="home-reassurance__ugc-rail">
          <slider-component class="slider-mobile-gutter">
            <ul
              id="ReassuranceUGC-{{ section.id }}"
              class="list-unstyled slider slider--tablet slider--peek home-reassurance__ugc-list"
              role="list"
            >
              {%- for product in section.settings.ugc_collection.products -%}
                {%- if ugc_rendered >= ugc_limit -%}{%- break -%}{%- endif -%}
                {%- if product.featured_media != blank -%}
                  {%- assign ugc_rendered = ugc_rendered | plus: 1 -%}
                  <li class="slider__slide">
                    <a
                      href="{{ product.url }}"
                      class="home-reassurance__ugc-link"
                      aria-label="Shop this look: {{ product.title | escape }}"
                    >
                      {%- assign ugc_alt = product.featured_media.alt | default: product.title -%}
                      {{ product.featured_media | image_url: width: 600 | image_tag: loading: 'lazy', alt: ugc_alt }}
                      <span class="home-reassurance__ugc-overlay">
                        <span>Shop this look</span>
                      </span>
                    </a>
                  </li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
            <div class="slider-buttons">
              <button
                type="button"
                class="slider-button slider-button--prev"
                name="previous"
                aria-label="{{ 'general.slider.previous_slide' | t }}"
              >
                {% render 'icon-caret' %}
              </button>
              <button
                type="button"
                class="slider-button slider-button--next"
                name="next"
                aria-label="{{ 'general.slider.next_slide' | t }}"
              >
                {% render 'icon-caret' %}
              </button>
            </div>
          </slider-component>
          {%- if ugc_rendered == 0 -%}
            <p class="caption text-center" style="margin-top: 0.75rem;">
              Assign a UGC collection to show real family photos.
            </p>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Home reassurance",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Dress together with confidence"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Why 30k+ families trust Dress Like Mommy for matching outfits."
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h2", "label": "Medium" },
        { "value": "h1", "label": "Large" }
      ],
      "default": "h2"
    },
    {
      "type": "select",
      "id": "card_heading_size",
      "label": "Card heading size",
      "options": [
        { "value": "h4", "label": "Small" },
        { "value": "h3", "label": "Standard" }
      ],
      "default": "h3"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-2"
    },
    {
      "type": "header",
      "content": "UGC carousel"
    },
    {
      "type": "header",
      "content": "Review snippets"
    },
    {
      "type": "text",
      "id": "review_snippets_heading",
      "label": "Snippets heading",
      "default": "30k+ families share why they love us"
    },
    {
      "type": "textarea",
      "id": "review_snippets",
      "label": "Snippets (rating|quote|name)",
      "default": "5.0|Fits perfectly for our photo shoot.|Maya, CA\n4.9|Soft fabrics & no itchy seams for the kids.|Danielle, TX\n5.0|Shipping was faster than expected!|Erica, NY\n4.8|Matchy but still stylish for parents.|Leo, IL\n5.0|Exchange process was effortless.|Priya, WA\n4.9|Grandma, mom, and baby all loved the fit.|Angela, ON\n5.0|True-to-size for my tall husband.|Sara, FL\n4.8|Colors looked amazing in photos.|Michelle, CO\n5.0|Customer service was so helpful with sizing.|Tanya, GA\n4.9|Quality rivals boutique brands.|Kristen, NJ\n5.0|My teens actually like matching now.|Megan, CA\n4.9|Fabric feels luxe but washes easily.|Allie, OR\n5.0|Best matching sets we’ve bought yet.|Verified buyer"
    },
    {
      "type": "collection",
      "id": "ugc_collection",
      "label": "UGC collection"
    },
    {
      "type": "text",
      "id": "ugc_heading",
      "label": "UGC heading",
      "default": "Real families in Dress Like Mommy"
    },
    {
      "type": "range",
      "id": "ugc_photo_limit",
      "min": 4,
      "max": 12,
      "step": 1,
      "label": "UGC images to show",
      "default": 6
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 32
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "truck", "label": "Truck" },
            { "value": "star", "label": "Star" },
            { "value": "exchange", "label": "Exchange" }
          ],
          "default": "star"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Free shipping always"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "2-3 day processing + tracked delivery worldwide."
        },
        {
          "type": "checkbox",
          "id": "enable_reviews_row",
          "label": "Show reviews rating row",
          "default": false
        },
        {
          "type": "text",
          "id": "reviews_rating",
          "label": "Average rating",
          "default": "4.8"
        },
        {
          "type": "text",
          "id": "reviews_scale",
          "label": "Rating scale max",
          "default": "5"
        },
        {
          "type": "text",
          "id": "reviews_count",
          "label": "Review count",
          "default": "30k+"
        },
        {
          "type": "url",
          "id": "reviews_link",
          "label": "Reviews link"
        },
        {
          "type": "text",
          "id": "reviews_link_label",
          "label": "Reviews link label",
          "default": "Read customer reviews"
        },
        {
          "type": "text",
          "id": "rating_note",
          "label": "Rating reassurance note",
          "default": "Colors and fits are tested for real family photoshoots."
        },
        {
          "type": "url",
          "id": "cta_link",
          "label": "CTA link"
        },
        {
          "type": "text",
