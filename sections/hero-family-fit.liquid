{{ 'section-image-banner.css' | asset_url | stylesheet_tag }}

{%- assign video_overlay_alpha = section.settings.video_overlay_opacity | times: 0.01 -%}

{%- style -%}
  .section-{{ section.id }}-hero {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-hero {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .hero-family-fit__grid {
    display: grid;
    gap: 3rem;
    align-items: center;
  }

  @media screen and (min-width: 990px) {
    .hero-family-fit__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .hero-family-fit__grid.hero-family-fit__grid--media-left {
      direction: rtl;
    }

    .hero-family-fit__grid.hero-family-fit__grid--media-left > * {
      direction: ltr;
    }
  }

  .hero-family-fit__content {
    max-width: 560px;
  }

  .hero-family-fit__eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.28em;
    font-size: 0.8rem;
    margin-bottom: 1rem;
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
  }

  .hero-family-fit__eyebrow::before {
    content: '';
    display: inline-block;
    width: 32px;
    height: 1px;
    background: currentColor;
    opacity: 0.4;
  }

  .hero-family-fit__heading {
    margin: 0 0 1rem;
    font-size: clamp(2.25rem, 3vw, 3.2rem);
    line-height: 1.1;
  }

  .hero-family-fit__body {
    margin-bottom: 1.5rem;
    font-size: 1.1rem;
    line-height: 1.6;
    color: rgba(var(--color-foreground), 0.85);
  }

  .hero-family-fit__shipping {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    font-size: 0.95rem;
    margin: 0 0 1.5rem;
  }
    background: rgba(var(--color-foreground), 0.04);
    border-radius: 999px;
    padding: 0.75rem 1.25rem;
  }

  .hero-family-fit__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .hero-family-fit__badge-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 0.75rem;
  }

  .hero-family-fit__badges {
    margin: 0;
    padding: 0;
    list-style: none;
    display: contents;
  }

  .hero-family-fit__badge {
    border: 1px solid rgba(var(--color-foreground), 0.12);
    border-radius: 16px;
    padding: 0.85rem 1rem;
    font-size: 0.9rem;
    font-weight: 600;
    background: rgba(var(--color-background), 0.7);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
  }

  .hero-family-fit__badge::before {
    content: '';
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: currentColor;
    opacity: 0.5;
  }

  .hero-family-fit__media picture,
  .hero-family-fit__media img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: {{ settings.media_radius }}px;
    overflow: hidden;
  }

  .hero-family-fit__video {
    position: relative;
    border-radius: {{ settings.media_radius }}px;
    overflow: hidden;
    box-shadow: 0 35px 60px rgba(0, 0, 0, 0.2);
    aspect-ratio: 16 / 9;
  }

  .hero-family-fit__video video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hero-family-fit__video::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.12) 0%, rgba(0, 0, 0, 0.05) 100%);
    opacity: {{ video_overlay_alpha }};
  }

  @media screen and (max-width: 989px) {
    .hero-family-fit__grid {
      gap: 2rem;
    }

    .hero-family-fit__content {
      max-width: none;
    }

    .hero-family-fit__video {
      aspect-ratio: 3 / 4;
      box-shadow: 0 25px 45px rgba(0, 0, 0, 0.15);
    }

    .hero-family-fit__shipping {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }

    .hero-family-fit__ctas {
      flex-direction: column;
    }

    .hero-family-fit__ctas .button {
      width: 100%;
      text-align: center;
    }

    .hero-family-fit__badge-grid {
      grid-template-columns: 1fr;
    }
  }
{%- endstyle -%}

{%- liquid
  assign animate = settings.animations_reveal_on_scroll
  assign shipping_copy = section.settings.shipping_message | strip

  if shipping_copy == blank
    if settings.shipping_processing_days_min and settings.shipping_processing_days_max and settings.shipping_transit_days_min and settings.shipping_transit_days_max
      assign shipping_copy = 'Free shipping on all clothing · Processing ' | append: settings.shipping_processing_days_min | append: '-' | append: settings.shipping_processing_days_max | append: ' business days + ' | append: settings.shipping_transit_days_min | append: '-' | append: settings.shipping_transit_days_max | append: ' business days transit'
    else
      assign shipping_copy = 'Free shipping on all clothing · 2-3 day processing · 7-10 day delivery window'
    endif
  endif

  assign has_desktop_video = false
  if section.settings.desktop_video_url != blank
    assign has_desktop_video = true
  endif

  assign has_mobile_video = false
  if section.settings.mobile_video_url != blank
    assign has_mobile_video = true
  endif

  assign has_desktop_image = false
  if section.settings.desktop_image != blank
    assign has_desktop_image = true
  endif

  assign has_mobile_image = false
  if section.settings.mobile_image != blank
    assign has_mobile_image = true
  endif

  assign has_media = false
  if has_desktop_video
    assign has_media = true
  elsif has_mobile_video
    assign has_media = true
  elsif has_desktop_image
    assign has_media = true
  elsif has_mobile_image
    assign has_media = true
  endif
  assign reverse_layout = false
  if section.settings.layout == 'media_left'
    assign reverse_layout = true
  endif
-%}

<section class="hero-family-fit section-{{ section.id }}-hero color-{{ section.settings.color_scheme }} gradient" data-hero-id="family-fit" data-hero-section="{{ section.id }}">
  <div class="page-width">
    <div class="hero-family-fit__grid{% if reverse_layout %} hero-family-fit__grid--media-left{% endif %}">
      <div class="hero-family-fit__content{% if animate %} scroll-trigger animate--slide-in{% endif %}">
        {%- if section.settings.eyebrow != blank -%}
          <p class="hero-family-fit__eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h1 class="hero-family-fit__heading {{ section.settings.heading_size }}">{{ section.settings.heading }}</h1>
        {%- endif -%}

        {%- if section.settings.body != blank -%}
          <div class="hero-family-fit__body rte">{{ section.settings.body }}</div>
        {%- endif -%}

        {%- if shipping_copy != blank -%}
          <p class="hero-family-fit__shipping">
            {% render 'icon-delivery-truck' %}
            <span>{{ shipping_copy }}</span>
          </p>
        {%- endif -%}

        <div class="hero-family-fit__ctas">
          {%- if section.settings.primary_label != blank and section.settings.primary_link != blank -%}
            <a
              href="{{ section.settings.primary_link }}"
              class="button button--primary"
              data-cta-id="hero_primary"
            >
              {{ section.settings.primary_label }}
            </a>
          {%- endif -%}

          {%- if section.settings.secondary_label != blank and section.settings.secondary_link != blank -%}
            <a
              href="{{ section.settings.secondary_link }}"
              class="button button--secondary"
              data-cta-id="hero_secondary"
            >
              {{ section.settings.secondary_label }}
            </a>
          {%- endif -%}
        </div>

        {%- if section.blocks.size > 0 -%}
          <div class="hero-family-fit__badge-grid">
            <ul class="hero-family-fit__badges" role="list">
              {%- for block in section.blocks -%}
                <li class="hero-family-fit__badge" {{ block.shopify_attributes }}>
                  {{ block.settings.text }}
                </li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
      </div>

      {%- if has_media -%}
        <div class="hero-family-fit__media{% if animate %} scroll-trigger animate--slide-in{% endif %}">
          {%- assign poster_image = section.settings.video_poster_image -%}
          {%- assign poster_url = '' -%}
          {%- if section.settings.video_poster_custom != blank -%}
            {%- assign poster_url = section.settings.video_poster_custom -%}
          {%- else -%}
            {%- if poster_image == blank and has_desktop_image -%}
              {%- assign poster_image = section.settings.desktop_image -%}
            {%- elsif poster_image == blank and has_mobile_image -%}
              {%- assign poster_image = section.settings.mobile_image -%}
            {%- endif -%}
            {%- if poster_image != blank -%}
              {%- assign poster_url = poster_image | image_url: width: 1600 -%}
            {%- endif -%}
          {%- endif -%}
          {%- if has_desktop_video or has_mobile_video -%}
            <div class="hero-family-fit__video">
              <video
                autoplay
                loop
                muted
                playsinline
                data-hero-video="primary"
                {% if poster_url != blank %}
                  poster="{{ poster_url }}"
                {% endif %}
              >
                {%- if has_mobile_video -%}
                  <source
                    src="{{ section.settings.mobile_video_url }}"
                    media="(max-width: 749px)"
                    type="video/mp4"
                  >
                {%- endif -%}
                {%- if has_desktop_video -%}
                  <source
                    src="{{ section.settings.desktop_video_url }}"
                    media="(min-width: 750px)"
                    type="video/mp4"
                  >
                {%- endif -%}
              </video>
            </div>
          {%- elsif has_desktop_image or has_mobile_image -%}
            <picture>
              {%- if has_mobile_image -%}
                <source
                  media="(max-width: 749px)"
                  srcset="{{ section.settings.mobile_image | image_url: width: 900 }}"
                >
              {%- endif -%}
              {%- if has_desktop_image -%}
                {{
                  section.settings.desktop_image
                  | image_url: width: 1600
                  | image_tag:
                    loading: 'lazy',
                    widths: '800, 1200, 1600',
                    sizes: '(max-width: 989px) 100vw, 50vw'
                }}
              {%- else -%}
                {{
                  section.settings.mobile_image
                  | image_url: width: 1600
                  | image_tag:
                    loading: 'lazy',
                    widths: '800, 1200, 1600',
                    sizes: '(max-width: 989px) 100vw, 50vw'
                }}
              {%- endif -%}
            </picture>
          {%- else -%}
            {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Family fit hero",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Match every moment"
    },
    {
      "type": "url",
      "id": "desktop_video_url",
      "label": "Desktop video URL",
      "info": "Paste a Shopify-hosted MP4 (ideal length 8s). Overrides the desktop image when provided."
    },
    {
      "type": "url",
      "id": "mobile_video_url",
      "label": "Mobile video URL",
      "info": "Paste a Shopify-hosted MP4 (9:16). Overrides the mobile image when provided."
    },
    {
      "type": "image_picker",
      "id": "video_poster_image",
      "label": "Video poster image",
      "info": "Fallback image shown before playback. Recommended 3200x1800."
    },
    {
      "type": "url",
      "id": "video_poster_custom",
      "label": "Video poster URL",
      "info": "Optional CDN image to use as poster (overrides image picker)."
    },
    {
      "type": "range",
      "id": "video_overlay_opacity",
      "label": "Video overlay opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 20
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Coordinated outfits made effortless</p>"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body copy",
      "default": "<p>From Mommy &amp; Me dresses to resort-ready swim, we curate fits that keep the whole family photo-ready without the couture price tag. Inclusive sizes, easy exchanges, always free shipping.</p>"
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Shop Mommy & Me"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "Take the gift quiz"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    },
    {
      "type": "text",
      "id": "shipping_message",
      "label": "Shipping reassurance override",
      "info": "Leave blank to auto-generate from theme shipping settings.",
      "default": "Free shipping on all clothing · 2-3 day processing + 7-10 day delivery window"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        {
          "value": "h1",
          "label": "Large"
        },
        {
          "value": "h2",
          "label": "Medium"
        }
      ],
      "default": "h1"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Desktop layout",
      "options": [
        {
          "value": "media_right",
          "label": "Copy left, media right"
        },
        {
          "value": "media_left",
          "label": "Copy right, media left"
        }
      ],
      "default": "media_right"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-2"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 52
    }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Badge",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Badge text",
          "default": "30k families styled"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Family fit hero",
      "category": "Hero"
    }
  ]
}
{% endschema %}
