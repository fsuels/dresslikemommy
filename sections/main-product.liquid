          { threshold: 0 }
        );
        mediaObserver.observe(mediaContainer);
      }

      if (variantSelects) {
        variantSelects.addEventListener('change', function (event) {
          markRequiredSelectionFromEvent(event);
          window.requestAnimationFrame(syncStickyState);
        });
        variantSelects.addEventListener('click', function (event) {
          markRequiredSelectionFromEvent(event);
          window.requestAnimationFrame(syncStickyState);
        });
      }

      var atcObserver = new MutationObserver(syncStickyState);
      atcObserver.observe(atcBtn, {
        attributes: true,
        attributeFilter: ['disabled'],
        childList: true,
        subtree: true,
        characterData: true,
      });

      if (priceContainer) {
        var priceObserver = new MutationObserver(syncStickyPrice);
        priceObserver.observe(priceContainer, {
          childList: true,
          subtree: true,
          characterData: true,
        });
      }

      function handleViewportChange() {
        if (!mobileMedia.matches) sticky.classList.remove('visible');
        syncStickyState();
      }

      if (typeof mobileMedia.addEventListener === 'function') {
        mobileMedia.addEventListener('change', handleViewportChange);
      } else if (typeof mobileMedia.addListener === 'function') {
        mobileMedia.addListener(handleViewportChange);
      }

      syncStickyState();
    })();
  </script>
