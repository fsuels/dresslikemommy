{%- comment -%} Sticky mobile Add to Cart bar {%- endcomment -%}
{%- if product.available -%}
  <div class="sticky-mobile-atc" id="StickyMobileATC-{{ section.id }}">
    <div class="sticky-mobile-atc__details">
      <span class="sticky-mobile-atc__price" data-sticky-mobile-atc-price>
        {{- product.selected_or_first_available_variant.price | money -}}
      </span>
      <span class="sticky-mobile-atc__size" data-sticky-mobile-atc-size hidden></span>
    </div>
    <button type="button" class="sticky-mobile-atc__btn" data-sticky-mobile-atc-button>
      {{- 'products.product.add_to_cart' | t -}}
    </button>
  </div>
  <script>
    (function () {
      var sticky = document.getElementById('StickyMobileATC-{{ section.id }}');
      if (!sticky) return;

      var mobileMedia = window.matchMedia('(max-width: 749px)');
      var stickyBtn = sticky.querySelector('[data-sticky-mobile-atc-button]');
      var stickyPrice = sticky.querySelector('[data-sticky-mobile-atc-price]');
      var stickySize = sticky.querySelector('[data-sticky-mobile-atc-size]');
      var mediaContainer =
        document.getElementById('GalleryViewer-{{ section.id }}') ||
        document.getElementById('MediaGallery-{{ section.id }}');
      var productForm = document.getElementById('product-form-{{ section.id }}');
      var atcBtn = document.getElementById('ProductSubmitButton-{{ section.id }}');
      var variantSelects = document.getElementById('variant-selects-{{ section.id }}');
      var priceContainer = document.getElementById('price-{{ section.id }}');
      var atcIsInViewport = true;
      var mediaIsInViewport = !!mediaContainer;
      var canShowSticky = true;
      var hasUserConfirmedSizeSelection = false;
      var hasUserConfirmedColorSelection = false;
      var highlightedGroup = null;
      var addToCartLabel = {{ 'products.product.add_to_cart' | t | json }};
      var chooseOptionsLabel = 'Choose options';
      var chooseSizeLabel = 'Select size';
      var chooseColorLabel = 'Select color';
      var sizeRequiredMessageText = 'Please select a size before adding to cart.';

      if (!atcBtn && productForm) atcBtn = productForm.querySelector('[name="add"]');
      if (!atcBtn || !stickyBtn) return;

      function getButtonLabel() {
        var labelNode = atcBtn.querySelector('span');
        if (!labelNode) return addToCartLabel;
        var labelText = labelNode.textContent ? labelNode.textContent.trim() : '';
        return labelText || addToCartLabel;
      }

      function setButtonText(button, text) {
        if (!button || !text) return;
        var labelNode = button.querySelector('span');
        if (!labelNode) return;
        var nextText = String(text).trim();
        if (!nextText) return;
        if (labelNode.textContent && labelNode.textContent.trim() === nextText) return;
        labelNode.textContent = nextText;
      }

      function syncBodyOffset(isVisible) {
        if (!document.body) return;

        if (isVisible) {
          document.body.classList.add('sticky-mobile-atc-visible');
          document.body.style.setProperty('--sticky-mobile-atc-offset', sticky.offsetHeight + 'px');
          return;
        }

        document.body.classList.remove('sticky-mobile-atc-visible');
        document.body.style.removeProperty('--sticky-mobile-atc-offset');
      }

      function toggleStickyVisibility() {
        var shouldShow = mobileMedia.matches && !atcIsInViewport && !mediaIsInViewport && canShowSticky;
        sticky.classList.toggle('visible', shouldShow);
        sticky.setAttribute('aria-hidden', shouldShow ? 'false' : 'true');
        syncBodyOffset(shouldShow);
      }

      function getOptionNameFromGroup(group) {
        if (!group) return '';

        var select = group.querySelector('select[name]');
        if (select && select.name) {
          var selectMatch = select.name.match(/^options\[(.+)\]$/);
          return (selectMatch ? selectMatch[1] : select.name).trim();
        }

        var radio = group.querySelector('input[type="radio"][name]');
        if (radio && radio.name) return radio.name.trim();

        var label = group.querySelector('legend, label.form__label, .form__label');
        if (!label || !label.textContent) return '';

        var labelText = label.textContent.replace(/\s+/g, ' ').trim();
        if (labelText.indexOf(':') > -1) labelText = labelText.split(':')[0];
        return labelText.trim();
      }

      function isSizeOptionGroup(group) {
        return /\bsize\b/.test(getOptionNameFromGroup(group).toLowerCase());
      }

      function isColorOptionGroup(group) {
        return /\bcolou?r\b/.test(getOptionNameFromGroup(group).toLowerCase());
      }

      function getSelectedOptionValue(group) {
        if (!group) return '';

        var select = group.querySelector('select');
        if (select) return (select.value || '').trim();

        var checkedRadio = group.querySelector('input[type="radio"]:checked');
        if (checkedRadio) return (checkedRadio.value || '').trim();

        return '';
      }

      function isInteractiveOptionGroup(group) {
        if (!group || group.hidden) return false;

        var computedStyle = window.getComputedStyle(group);
        return computedStyle.display !== 'none' && computedStyle.visibility !== 'hidden';
      }

      function markRequiredSelectionFromEvent(event) {
        if (!event || !event.target) return;

        var control = event.target.closest('select, input[type="radio"]');
        if (!control) return;

        var group = control.closest('.product-form__input');
        if (!group || !isInteractiveOptionGroup(group)) return;

        var selectedValue = getSelectedOptionValue(group) !== '';
        if (isSizeOptionGroup(group)) hasUserConfirmedSizeSelection = selectedValue;
        if (isColorOptionGroup(group)) hasUserConfirmedColorSelection = selectedValue;
