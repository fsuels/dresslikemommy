      function getSizeSelectionState() {
        var selectionState = {
          hasSizeOption: false,
          totalSizeOptions: 0,
          selectedSizeValues: [],
          sizeOptionGroups: [],
          isComplete: true,
          missingSizeOption: null,
          firstSizeOption: null,
