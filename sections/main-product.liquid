          existingPrompt.setAttribute('data-size-required-message', '');
          existingPrompt.setAttribute('role', 'status');
          existingPrompt.setAttribute('aria-live', 'polite');
          existingPrompt.textContent = sizeRequiredMessageText;
          group.appendChild(existingPrompt);
        }

        group.classList.toggle('product-form__input--size-required', shouldShow);
        if (shouldShow) {
          existingPrompt.removeAttribute('hidden');
          return;
        }

        existingPrompt.setAttribute('hidden', 'hidden');
      }

      function syncSizePrompt(sizeSelectionState, showPrompt) {
        var currentSizeState = sizeSelectionState || getSizeSelectionState();
        var targetGroup =
          showPrompt &&
          (currentSizeState.missingSizeOption
            ? currentSizeState.missingSizeOption.group
            : currentSizeState.firstSizeOption
              ? currentSizeState.firstSizeOption.group
              : null);

        currentSizeState.sizeOptionGroups.forEach(function (group) {
          setSizePromptVisibility(group, !!targetGroup && group === targetGroup);
        });

        if (!showPrompt) return;

        if (!atcBtn.hasAttribute('disabled')) {
          atcBtn.setAttribute('disabled', 'disabled');
        }
        setButtonText(atcBtn, chooseSizeLabel);
      }

      function syncStickyPrice() {
        if (!stickyPrice || !priceContainer) return;

        var salePrice = priceContainer.querySelector('.price__sale .price-item--sale');
        var regularPrice = priceContainer.querySelector('.price__regular .price-item--regular');
        var fallbackPrice = priceContainer.querySelector('.price-item');
        var activePrice = salePrice || regularPrice || fallbackPrice;

        if (!activePrice || !activePrice.textContent) return;

        var priceText = activePrice.textContent.replace(/\s+/g, ' ').trim();
        if (priceText) stickyPrice.textContent = priceText;
      }

      function syncStickySize(sizeSelectionState) {
        if (!stickySize) return;

        var currentSizeState = sizeSelectionState || getSizeSelectionState();
        if (currentSizeState.hasSizeOption && currentSizeState.selectedSizeValues.length) {
          stickySize.textContent = 'Size: ' + currentSizeState.selectedSizeValues.join(' / ');
          stickySize.removeAttribute('hidden');
          return;
        }

        stickySize.textContent = '';
        stickySize.setAttribute('hidden', 'hidden');
      }

      function syncStickyState() {
        var sizeSelectionState = getSizeSelectionState();
        var colorSelectionState = getColorSelectionState();
        var missingOption = getFirstMissingOption();
        var showSizePrompt =
          sizeSelectionState.hasSizeOption &&
          !sizeSelectionState.isComplete &&
          (!colorSelectionState.hasColorOption || hasUserConfirmedColorSelection);
        syncStickyPrice();
        syncStickySize(sizeSelectionState);
        syncSizePrompt(sizeSelectionState, showSizePrompt);

        if (sizeSelectionState.hasSizeOption && (!hasUserConfirmedSizeSelection || !sizeSelectionState.isComplete)) {
          canShowSticky = false;
          sticky.classList.add('requires-options');
          stickyBtn.textContent = chooseSizeLabel;
          stickyBtn.removeAttribute('disabled');
          toggleStickyVisibility();
          return;
        }

        if (colorSelectionState.hasColorOption && (!hasUserConfirmedColorSelection || !colorSelectionState.isComplete)) {
          canShowSticky = false;
          sticky.classList.add('requires-options');
          stickyBtn.textContent = chooseColorLabel;
          stickyBtn.removeAttribute('disabled');
          toggleStickyVisibility();
          return;
        }

        if (missingOption) {
          canShowSticky = false;
          sticky.classList.add('requires-options');
          stickyBtn.textContent = chooseOptionsLabel;
          stickyBtn.removeAttribute('disabled');
          toggleStickyVisibility();
          return;
        }

        canShowSticky = true;
        sticky.classList.remove('requires-options');
        stickyBtn.textContent = getButtonLabel();

        if (atcBtn.hasAttribute('disabled')) {
          stickyBtn.setAttribute('disabled', 'disabled');
        } else {
          stickyBtn.removeAttribute('disabled');
        }

        toggleStickyVisibility();
      }

      stickyBtn.addEventListener('click', function (event) {
        var sizeSelectionState = getSizeSelectionState();
        if (sizeSelectionState.hasSizeOption && (!hasUserConfirmedSizeSelection || !sizeSelectionState.isComplete)) {
          event.preventDefault();
          scrollToMissingOption(
            sizeSelectionState.missingSizeOption || sizeSelectionState.firstSizeOption || getFirstMissingOption()
          );
          return;
        }

        var colorSelectionState = getColorSelectionState();
        if (colorSelectionState.hasColorOption && (!hasUserConfirmedColorSelection || !colorSelectionState.isComplete)) {
          event.preventDefault();
          scrollToMissingOption(
            colorSelectionState.missingColorOption || colorSelectionState.firstColorOption || getFirstMissingOption()
          );
          return;
        }

        var missingOption = getFirstMissingOption();

        if (missingOption) {
          event.preventDefault();
          scrollToMissingOption(missingOption);
          return;
        }

        if (atcBtn.hasAttribute('disabled')) return;
        atcBtn.click();
      });

      var visibilityObserver = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (entry) {
            atcIsInViewport = entry.isIntersecting;
            toggleStickyVisibility();
          });
