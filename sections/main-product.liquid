        if (!variantSelects) return selectionState;

        var optionGroups = Array.from(variantSelects.querySelectorAll('.product-form__input'));
        for (var i = 0; i < optionGroups.length; i += 1) {
          var group = optionGroups[i];
          if (!isInteractiveOptionGroup(group)) continue;
          if (!isSizeOptionGroup(group)) continue;

          selectionState.hasSizeOption = true;
          selectionState.totalSizeOptions += 1;
          selectionState.sizeOptionGroups.push(group);
          if (!selectionState.firstSizeOption) {
            selectionState.firstSizeOption = {
              group: group,
              focusTarget: group.querySelector('select, input[type="radio"]'),
              anchor: group.querySelector('label, legend, .form__label') || group,
            };
          }
          var selectedValue = getSelectedOptionValue(group);
          if (selectedValue !== '') {
            selectionState.selectedSizeValues.push(selectedValue);
          } else if (!selectionState.missingSizeOption) {
            selectionState.missingSizeOption = {
              group: group,
              focusTarget: group.querySelector('select, input[type="radio"]'),
              anchor: group.querySelector('label, legend, .form__label') || group,
            };
          }
        }

        selectionState.isComplete =
          !selectionState.hasSizeOption ||
          selectionState.selectedSizeValues.length === selectionState.totalSizeOptions;

        if (selectionState.isComplete) {
          selectionState.missingSizeOption = null;
        }

        return selectionState;
      }

      function getColorSelectionState() {
        var selectionState = {
          hasColorOption: false,
          totalColorOptions: 0,
          selectedColorValues: [],
          isComplete: true,
          missingColorOption: null,
          firstColorOption: null,
        };

        if (!variantSelects) return selectionState;

        var optionGroups = Array.from(variantSelects.querySelectorAll('.product-form__input'));
        for (var i = 0; i < optionGroups.length; i += 1) {
          var group = optionGroups[i];
          if (!isInteractiveOptionGroup(group)) continue;
          if (!isColorOptionGroup(group)) continue;

          selectionState.hasColorOption = true;
          selectionState.totalColorOptions += 1;
          if (!selectionState.firstColorOption) {
            selectionState.firstColorOption = {
              group: group,
              focusTarget: group.querySelector('select, input[type="radio"]'),
              anchor: group.querySelector('label, legend, .form__label') || group,
            };
          }
          var selectedValue = getSelectedOptionValue(group);
          if (selectedValue !== '') {
            selectionState.selectedColorValues.push(selectedValue);
          } else if (!selectionState.missingColorOption) {
            selectionState.missingColorOption = {
              group: group,
              focusTarget: group.querySelector('select, input[type="radio"]'),
              anchor: group.querySelector('label, legend, .form__label') || group,
            };
          }
        }

        selectionState.isComplete =
          !selectionState.hasColorOption ||
          selectionState.selectedColorValues.length === selectionState.totalColorOptions;

        if (selectionState.isComplete) {
          selectionState.missingColorOption = null;
        }

        return selectionState;
      }

      function getFirstMissingOption() {
        if (!variantSelects) return null;

        var optionGroups = Array.from(variantSelects.querySelectorAll('.product-form__input'));
        for (var i = 0; i < optionGroups.length; i += 1) {
          var group = optionGroups[i];
          if (!isInteractiveOptionGroup(group)) continue;
          var select = group.querySelector('select');
          if (select && select.value === '') {
            return {
              group: group,
              focusTarget: select,
              anchor: group.querySelector('label, legend, .form__label') || group,
            };
          }

          var radios = Array.from(group.querySelectorAll('input[type="radio"]'));
          if (radios.length && !group.querySelector('input[type="radio"]:checked')) {
            return {
              group: group,
              focusTarget: radios[0],
              anchor: group.querySelector('legend, .form__label') || group,
            };
          }
        }

        return null;
      }

      function highlightOptionGroup(group) {
        if (!group) return;

        if (highlightedGroup && highlightedGroup !== group) {
          highlightedGroup.classList.remove('sticky-option-target--highlight');
        }

        highlightedGroup = group;
        group.classList.add('sticky-option-target--highlight');

        window.setTimeout(function () {
          group.classList.remove('sticky-option-target--highlight');
          if (highlightedGroup === group) highlightedGroup = null;
        }, 1400);
      }

      function scrollToMissingOption(missingOption) {
        if (!missingOption) return;

        highlightOptionGroup(missingOption.group);

        var anchor = missingOption.anchor || missingOption.group || missingOption.focusTarget;
        if (anchor && anchor.getBoundingClientRect) {
          var offset = 112;
          var topPosition = window.scrollY + anchor.getBoundingClientRect().top - offset;
          window.scrollTo({ top: Math.max(topPosition, 0), behavior: 'smooth' });
