{% style %}
  .home-outfits-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .home-outfits-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .home-outfits__grid {
    display: grid;
    gap: 1.5rem;
  }

  @media screen and (min-width: 990px) {
    .home-outfits__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .home-outfits__card {
    border-radius: 24px;
    overflow: hidden;
    background: rgba(var(--color-background), 1);
    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.08);
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .home-outfits__media img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .home-outfits__content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    height: 100%;
  }

  .home-outfits__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .home-outfits__tag {
    border-radius: 999px;
    padding: 0.35rem 0.85rem;
    font-size: 0.75rem;
    border: 1px solid rgba(var(--color-foreground), 0.18);
  }

  .home-outfits__cta {
    margin-top: auto;
  }
{% endstyle %}

<section class="home-outfits-{{ section.id }} color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width">
    <div class="title-wrapper-with-link">
      <div>
        <h2 class="{{ section.settings.heading_size }}">{{ section.settings.heading }}</h2>
        {% if section.settings.subheading != blank %}
          <p class="home-reassurance__subheading">{{ section.settings.subheading }}</p>
        {% endif %}
      </div>
      {% if section.settings.view_all_link != blank %}
        <a href="{{ section.settings.view_all_link }}" class="link underlined-link" data-cta-id="outfits_view_all" data-cta-scope="outfits">
          {{ section.settings.view_all_label }}
        </a>
      {% endif %}
    </div>

    <div class="home-outfits__grid">
      {% for block in section.blocks %}
        <article class="home-outfits__card" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            <div class="home-outfits__media">
              {{ block.settings.image | image_url: width: 900 | image_tag: loading: 'lazy', widths: '400, 600, 900', sizes: '(max-width: 989px) 100vw, 33vw' }}
            </div>
          {% endif %}
          <div class="home-outfits__content">
            {% if block.settings.tags != blank %}
              <div class="home-outfits__tags">
                {% assign tags = block.settings.tags | split: ',' %}
                {% for tag in tags %}
                  <span class="home-outfits__tag">{{ tag | strip }}</span>
                {% endfor %}
              </div>
            {% endif %}
            <h3>{{ block.settings.title }}</h3>
            <p class="rte">{{ block.settings.description }}</p>
            {% if block.settings.product_1 != blank or block.settings.product_2 != blank %}
              <ul class="list-unstyled">
                {% if block.settings.product_1 != blank %}
                  <li><a href="{{ block.settings.product_1 }}" class="link" data-cta-id="outfit_product" data-cta-scope="outfits">Shop look</a></li>
                {% endif %}
                {% if block.settings.product_2 != blank %}
                  <li><a href="{{ block.settings.product_2 }}" class="link" data-cta-id="outfit_product" data-cta-scope="outfits">Shop accessories</a></li>
                {% endif %}
              </ul>
            {% endif %}
            {% if block.settings.cta_label != blank and block.settings.cta_link != blank %}
              <div class="home-outfits__cta">
                <a href="{{ block.settings.cta_link }}" class="button button--tertiary" data-cta-id="outfit_cta" data-cta-scope="outfits">
                  {{ block.settings.cta_label }}
                </a>
              </div>
            {% endif %}
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Home outfit stories",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Match the moment"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Outfit recipes for beach days, brunch, and holiday cards."
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h2", "label": "Medium" },
        { "value": "h1", "label": "Large" }
      ],
      "default": "h2"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View all link"
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View all label",
      "default": "Browse all outfit guides"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "story",
      "name": "Outfit story",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Coastal brunch"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Linen blends and pastel accessories keep everyone cool and polished."
        },
        {
          "type": "text",
          "id": "tags",
          "label": "Tags (comma-separated)",
          "default": "Brunch, Coastal, Spring"
        },
        {
          "type": "url",
          "id": "product_1",
          "label": "Primary product link"
        },
        {
          "type": "url",
          "id": "product_2",
          "label": "Secondary product link"
        },
        {
          "type": "url",
          "id": "cta_link",
          "label": "CTA link"
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "CTA label",
          "default": "View guide"
        }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "Home outfit stories",
      "blocks": [
        { "type": "story" },
        { "type": "story" },
        { "type": "story" }
      ]
    }
  ]
}
{% endschema %}
