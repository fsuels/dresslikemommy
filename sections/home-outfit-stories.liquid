{% style %}
  .home-outfits-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .home-outfits-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .home-outfits__grid {
    display: grid;
    gap: 1.5rem;
  }

  @media screen and (min-width: 990px) {
    .home-outfits__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .home-outfits__card {
    border-radius: 28px;
    overflow: hidden;
    position: relative;
    min-height: 420px;
    box-shadow: 0 40px 60px rgba(0, 0, 0, 0.15);
    color: #fff;
    display: flex;
    align-items: flex-end;
    isolation: isolate;
  }

  .home-outfits__card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(10, 10, 10, 0.2) 0%, rgba(10, 10, 10, 0.75) 70%);
    z-index: 1;
  }

  .home-outfits__card-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .home-outfits__card-content {
    position: relative;
    z-index: 2;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    width: 100%;
  }

  .home-outfits__card-title {
    font-size: clamp(1.5rem, 2.2vw, 2.2rem);
    margin: 0;
  }

  .home-outfits__card-description {
    margin: 0;
    font-size: 1rem;
    max-width: 320px;
  }

  .home-outfits__thumb-row {
    display: flex;
    gap: 0.75rem;
  }

  .home-outfits__thumb {
    width: 64px;
    height: 64px;
    border-radius: 14px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.15);
    border: 1px solid rgba(255, 255, 255, 0.2);
    flex-shrink: 0;
  }

  .home-outfits__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .home-outfits__cta {
    margin-top: 0.5rem;
  }

  .home-outfits__cta .button {
    --color-button: #fff;
    --color-button-text: #111;
  }
{% endstyle %}

<section class="home-outfits-{{ section.id }} color-{{ section.settings.color_scheme }} gradient section-band section-band--muted">
  <div class="page-width">
    <div class="title-wrapper-with-link">
      <div>
        <h2 class="section-heading {{ section.settings.heading_size }}">{{ section.settings.heading }}</h2>
        {% if section.settings.subheading != blank %}
          <p class="home-reassurance__subheading">{{ section.settings.subheading }}</p>
        {% endif %}
      </div>
      {% if section.settings.view_all_link != blank %}
        <a href="{{ section.settings.view_all_link }}" class="link underlined-link" data-cta-id="outfits_view_all" data-cta-scope="outfits">
          {{ section.settings.view_all_label }}
        </a>
      {% endif %}
    </div>

    <div class="home-outfits__grid">
      {% for block in section.blocks %}
        {%- assign moment_collection = block.settings.collection -%}
        {%- assign card_image = block.settings.image | default: moment_collection.featured_image -%}
        {%- assign product_limit = 4 -%}
        {%- assign button_label = block.settings.cta_label | default: 'Shop ' | append: block.settings.title | append: ' collection' -%}
        <article class="home-outfits__card" {{ block.shopify_attributes }}>
          {% if card_image != blank %}
            {{ card_image | image_url: width: 1400 | image_tag: class: 'home-outfits__card-image', loading: 'lazy', sizes: '(max-width: 989px) 100vw, 33vw', widths: '600, 900, 1400' }}
          {% else %}
            <div class="home-outfits__card-image" style="background: var(--color-foreground); opacity: 0.4;"></div>
          {% endif %}
          <div class="home-outfits__card-content">
        {% if block.settings.tags != blank %}
          <p class="caption-with-letter-spacing text-uppercase">{{ block.settings.tags }}</p>
        {% endif %}
            <h3 class="home-outfits__card-title">{{ block.settings.title }}</h3>
            {% if block.settings.description != blank %}
              <p class="home-outfits__card-description">{{ block.settings.description }}</p>
            {% endif %}
            {% if moment_collection != blank and moment_collection.products_count > 0 %}
              <div class="home-outfits__thumb-row">
                {% for product in moment_collection.products limit: product_limit %}
                  {% if product.featured_media != blank %}
                    <a class="home-outfits__thumb" href="{{ product.url }}" aria-label="{{ product.title | escape }}">
                      {{ product.featured_media | image_url: width: 160 | image_tag: loading: 'lazy', alt: product.featured_media.alt | default: product.title }}
                    </a>
                  {% endif %}
                {% endfor %}
              </div>
            {% endif %}
            <div class="home-outfits__cta">
              {% assign collection_url = moment_collection.url | default: block.settings.cta_link %}
              {% if collection_url != blank %}
                <a href="{{ collection_url }}" class="button button--primary" data-cta-id="outfit_cta" data-cta-scope="outfits">
                  {{ button_label | strip }}
                </a>
              {% endif %}
            </div>
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Home outfit stories",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Match the moment"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Outfit recipes for beach days, brunch, and holiday cards."
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h2", "label": "Medium" },
        { "value": "h1", "label": "Large" }
      ],
      "default": "h2"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View all link"
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View all label",
      "default": "Browse all outfit guides"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "story",
      "name": "Outfit story",
      "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Moment collection"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Coastal brunch sets"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Short description",
      "default": "Pastel linens + breezy suits for patio brunch photos."
    },
    {
      "type": "text",
      "id": "tags",
      "label": "Eyebrow label",
      "default": "Brunch moment"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Shop collection"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Fallback CTA link",
      "info": "Used if the collection is blank."
    }
  ]
}
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "Home outfit stories",
      "blocks": [
        { "type": "story" },
        { "type": "story" },
        { "type": "story" }
      ]
    }
  ]
}
{% endschema %}
