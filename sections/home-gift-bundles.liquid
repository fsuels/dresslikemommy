{% style %}
  .home-gift-bundles-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .home-gift-bundles-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .home-gift-bundles__grid {
    display: grid;
    gap: 1.5rem;
  }

  @media screen and (min-width: 990px) {
    .home-gift-bundles__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .home-gift-bundles__card {
    border-radius: 28px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    background: rgba(var(--color-background), 1);
    box-shadow: 0 25px 60px rgba(0, 0, 0, 0.08);
    min-height: 100%;
  }

  .home-gift-bundles__media img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .home-gift-bundles__content {
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    height: 100%;
  }
{% endstyle %}

<section class="home-gift-bundles-{{ section.id }} color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width">
    <div class="title-wrapper-with-link">
      <div>
        <h2 class="{{ section.settings.heading_size }}">{{ section.settings.heading }}</h2>
        {% if section.settings.subheading != blank %}
          <p class="home-reassurance__subheading">{{ section.settings.subheading }}</p>
        {% endif %}
      </div>
    </div>

    <div class="home-gift-bundles__grid">
      {% for block in section.blocks %}
        <article class="home-gift-bundles__card" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            <div class="home-gift-bundles__media">
              {{ block.settings.image | image_url: width: 900 | image_tag: loading: 'lazy', widths: '600, 900, 1200', sizes: '(max-width: 989px) 100vw, 50vw' }}
            </div>
          {% endif %}
          <div class="home-gift-bundles__content">
            <p class="home-outfits__tag">{{ block.settings.tagline }}</p>
            <h3>{{ block.settings.title }}</h3>
            <p class="rte">{{ block.settings.description }}</p>
            {% if block.settings.link != blank %}
              <a href="{{ block.settings.link }}" class="button button--secondary" data-cta-id="gift_bundle_cta" data-cta-scope="gift_bundles">
                {{ block.settings.cta_label }}
              </a>
            {% endif %}
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Home gift bundles",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Bundle the love"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Ready-made gift sets for family showers, holidays, and surprise trips."
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h2", "label": "Medium" },
        { "value": "h1", "label": "Large" }
      ],
      "default": "h2"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "bundle",
      "name": "Bundle",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "tagline",
          "label": "Tagline",
          "default": "Baby shower favorite"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Welcome-home bundle"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Matching swaddles + sibling tees ready to gift."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "CTA label",
          "default": "Shop bundle"
        }
      ]
    }
  ],
  "max_blocks": 2,
  "presets": [
    {
      "name": "Home gift bundles",
      "blocks": [
        { "type": "bundle" },
        { "type": "bundle" }
      ]
    }
  ]
}
{% endschema %}
