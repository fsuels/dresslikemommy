{%- liquid
  assign restrict_handle = section.settings.restrict_handle | strip
  if restrict_handle != blank and collection and collection.handle != restrict_handle
    assign skip_render = true
  endif
-%}

{%- unless skip_render -%}
{%- liquid
  assign current_handle = collection.handle | default: ''
  assign matched_intro_block = blank
  for block in section.blocks
    if block.type == 'intro-config' and block.settings.handle == current_handle
      assign matched_intro_block = block
      break
    endif
  endfor

  assign restrict_handle = section.settings.restrict_handle | strip
  assign should_render = true
  if current_handle == ''
    assign should_render = false
  elsif matched_intro_block == blank and restrict_handle != blank and restrict_handle != current_handle
    assign should_render = false
  endif

  assign eyebrow_text = section.settings.eyebrow
  assign intro_richtext = section.settings.intro_richtext
  assign links_heading = section.settings.links_heading
  assign color_scheme = section.settings.color_scheme
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign effective_handle = restrict_handle

  if matched_intro_block != blank
    if matched_intro_block.settings.eyebrow != blank
      assign eyebrow_text = matched_intro_block.settings.eyebrow
    endif
    if matched_intro_block.settings.intro_richtext != blank
      assign intro_richtext = matched_intro_block.settings.intro_richtext
    endif
    if matched_intro_block.settings.links_heading != blank
      assign links_heading = matched_intro_block.settings.links_heading
    endif
    if matched_intro_block.settings.color_scheme != blank
      assign color_scheme = matched_intro_block.settings.color_scheme
    endif
    if matched_intro_block.settings.padding_top != blank
      assign padding_top = matched_intro_block.settings.padding_top
    endif
    if matched_intro_block.settings.padding_bottom != blank
      assign padding_bottom = matched_intro_block.settings.padding_bottom
    endif
    if matched_intro_block.settings.handle != blank
      assign effective_handle = matched_intro_block.settings.handle
    else
      assign effective_handle = current_handle
    endif
  endif
-%}

{%- if should_render -%}
  {{ 'component-rte.css' | asset_url | stylesheet_tag }}

  {%- assign padding_top_mobile = padding_top | default: 0 -%}
  {%- assign padding_bottom_mobile = padding_bottom | default: 0 -%}

  {%- style -%}
    .collection-intro {
      border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    }

    .section-{{ section.id }}-padding {
      padding-top: {{ padding_top_mobile | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ padding_bottom_mobile | times: 0.75 | round: 0 }}px;
    }

    @media screen and (min-width: 750px) {
      .section-{{ section.id }}-padding {
        padding-top: {{ padding_top_mobile }}px;
        padding-bottom: {{ padding_bottom_mobile }}px;
      }
    }

    .collection-intro__content {
      max-width: 58rem;
      margin-bottom: 1.5rem;
    }

    .collection-intro__links {
      display: grid;
      gap: 1rem;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    }

    .collection-intro__card {
      display: flex;
      flex-direction: column;
      padding: 1.25rem;
      border: 1px solid rgba(0, 0, 0, 0.08);
      border-radius: var(--inputs-radius, 12px);
      text-decoration: none;
    }

    .collection-intro__card:hover,
    .collection-intro__card:focus-visible {
      border-color: currentColor;
    }

    .collection-intro__card-heading {
      font-size: 1rem;
      font-weight: 600;
      margin: 0 0 0.35rem;
    }

    .collection-intro__card-description {
      margin: 0;
      color: rgba(18, 18, 18, 0.75);
      font-size: 0.95rem;
    }

  {%- endstyle -%}

  {%- assign has_links = false -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'link' -%}
      {%- assign target_handle = block.settings.handle_target | strip -%}
      {%- if target_handle == '' -%}
        {%- assign target_handle = effective_handle -%}
      {%- endif -%}
      {%- if target_handle == blank or target_handle == current_handle -%}
        {%- assign has_links = true -%}
        {%- break -%}
      {%- endif -%}
    {%- endif -%}
  {%- endfor -%}

  <div class="collection-intro color-{{ color_scheme }} gradient">
    <div class="section-{{ section.id }}-padding page-width">
      {%- if eyebrow_text != blank -%}
        <p class="caption-with-letter-spacing">{{ eyebrow_text | escape }}</p>
      {%- endif -%}

      {%- if intro_richtext != blank -%}
        <div class="collection-intro__content rte">
          {{ intro_richtext }}
        </div>
      {%- endif -%}

      {%- if has_links -%}
        {%- if links_heading != blank -%}
          <h2 class="h4">{{ links_heading | escape }}</h2>
        {%- endif -%}
        <div class="collection-intro__links">
          {%- for block in section.blocks -%}
            {%- if block.type == 'link' -%}
              {%- assign target_handle = block.settings.handle_target | strip -%}
              {%- if target_handle == '' -%}
                {%- assign target_handle = effective_handle -%}
              {%- endif -%}
              {%- if target_handle == blank or target_handle == current_handle -%}
                {%- assign link_url = block.settings.link -%}
                {%- if link_url != blank -%}
                  <a
                    class="collection-intro__card"
                    href="{{ link_url }}"
                    {{ block.shopify_attributes }}
                  >
                {%- else -%}
                  <div class="collection-intro__card" {{ block.shopify_attributes }}>
                {%- endif -%}
                    <p class="collection-intro__card-heading">
                      {{- block.settings.title | escape -}}
                    </p>
                    {%- if block.settings.description != blank -%}
                      <p class="collection-intro__card-description">
                        {{- block.settings.description | escape -}}
                      </p>
                    {%- endif -%}
                {%- if link_url != blank -%}
                  </a>
                {%- else -%}
                  </div>
                {%- endif -%}
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
{%- endif -%}
{%- endunless -%}

{% schema %}
{
  "name": "Collection intro + links",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Mommy & me style guide"
    },
    {
      "type": "text",
      "id": "restrict_handle",
      "label": "Only show on collection handle",
      "info": "Leave blank to show on every collection. Enter the handle (e.g., mommy-and-me-dresses) to limit rendering."
    },
    {
      "type": "richtext",
      "id": "intro_richtext",
      "label": "Intro copy",
      "default": "<p>Matching Mommy & Me dresses should feel effortless. Layer floaty maxi dresses for mom with twirl-ready minis and you have a one-and-done look for photoshoots or brunch. Need alternates? Our <a href=\\\"/collections/matching-family-pajamas\\\">matching family pajamas</a> keep cozy nights coordinated, and <a href=\\\"/collections/mommy-and-me-swimsuits\\\">family swimsuits</a> bring the same vibe to beach days.</p>"
    },
    {
      "type": "text",
      "id": "links_heading",
      "label": "Links heading",
      "default": "Plan the rest of the look"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 32
    }
  ],
  "blocks": [
    {
      "type": "intro-config",
      "name": "Collection intro",
      "settings": [
        {
          "type": "text",
          "id": "handle",
          "label": "Collection handle",
          "info": "Enter the handle (e.g., mommy-and-me-dresses)."
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow"
        },
        {
          "type": "richtext",
          "id": "intro_richtext",
          "label": "Intro copy"
        },
        {
          "type": "text",
          "id": "links_heading",
          "label": "Links heading"
        },
        {
          "type": "color_scheme",
          "id": "color_scheme",
          "label": "Color scheme",
          "default": "scheme-1"
        },
        {
          "type": "range",
          "id": "padding_top",
          "min": 0,
          "max": 120,
          "step": 4,
          "unit": "px",
          "label": "Padding top",
          "default": 32
        },
        {
          "type": "range",
          "id": "padding_bottom",
          "min": 0,
          "max": 120,
          "step": 4,
          "unit": "px",
          "label": "Padding bottom",
          "default": 24
        }
      ]
    },
    {
      "type": "link",
      "name": "Link card",
      "settings": [
        {
          "type": "text",
          "id": "handle_target",
          "label": "Collection handle",
          "info": "Optional: only show this card for a specific collection handle."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Matching family pajamas"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Cozy coordinated sets for tree-trimming nights."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "max_blocks": 40,
  "presets": [
    {
      "name": "Collection intro + links",
      "blocks": [
        {
          "type": "link",
          "settings": {
            "title": "Matching family pajamas",
            "description": "Cozy sets for Christmas Eve and movie nights.",
            "link": "/collections/matching-family-pajamas"
          }
        },
        {
          "type": "link",
          "settings": {
            "title": "Family swimsuits",
            "description": "Resort-ready looks for pool days and getaways.",
            "link": "/collections/mommy-and-me-swimsuits"
          }
        },
        {
          "type": "link",
          "settings": {
            "title": "Family photo outfits (Fall/Winter)",
            "description": "Palette ideas, layering tips, and posing prompts.",
            "link": "/blogs/style-journal/family-photo-outfits-fall-winter"
          }
