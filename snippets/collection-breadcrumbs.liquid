{% comment %}
  Collection breadcrumbs with category navigation tabs.
  Uses metafields:
    - custom.category1: Parent category (e.g. "Mommy and Me"). Defaults to "Mommy and Me".
    - custom.product_tag: Comma-separated style/sub-collection links.
  Smart fallback: If product_tag contains top-level parent categories instead of
  subcategories, automatically uses product types from the collection instead.
  Cross-category collections (new-arrivals, etc.) show top-level category pills.
{% endcomment %}

{% assign parent_category = collection.metafields.custom.category1 | default: 'Mommy and Me' | strip %}
{% assign product_tags_raw = collection.metafields.custom.product_tag | default: '' %}
{% assign product_tags = product_tags_raw | split: ',' %}
{% assign current_collection_handle = collection.handle %}
{% assign current_collection_label = collection.title | strip %}
{% assign current_breadcrumb_label = current_collection_label %}
{% assign collections_base_url = routes.collections_url | append: '/' %}

{% if current_collection_handle == 'daddy-me' %}
  {% assign parent_category = 'Daddy & Me' %}
  {% assign current_breadcrumb_label = 'Daddy & Me' %}
{% elsif current_collection_handle == 'daddy-me-t-shirts' %}
  {% assign parent_category = 'Daddy & Me' %}
  {% assign current_breadcrumb_label = 'T-Shirts' %}
{% elsif current_collection_handle == 'trunks' %}
  {% assign parent_category = 'Daddy & Me' %}
{% elsif current_collection_handle == 'couples' %}
  {% assign parent_category = 'Couples' %}
  {% assign current_breadcrumb_label = 'Couples' %}
{% elsif current_collection_handle == 'maternity' %}
  {% assign parent_category = 'Maternity' %}
  {% assign current_breadcrumb_label = 'Maternity' %}
{% elsif current_collection_handle == 'new-women-outfits' or current_collection_handle == 'family-matching-outfits' %}
  {% assign parent_category = 'Family Matching' %}
  {% assign current_breadcrumb_label = 'Family Matching' %}
{% endif %}

{% comment %} --- Known top-level parent categories --- {% endcomment %}
{% assign top_level_categories = 'mommy-and-me,family-matching,daddy-and-me,maternity,couples' %}
{% assign top_level_labels = 'Mommy and Me,Daddy and Me,Couples,Maternity,Family Matching' %}

{% comment %} --- Cross-category / store-wide collections that should show top-level nav pills --- {% endcomment %}
{% assign cross_category_handles = 'new-arrivals,shop,all,sale,bestsellers' %}
{% assign is_cross_category = false %}
{% if cross_category_handles contains current_collection_handle %}
  {% assign is_cross_category = true %}
{% endif %}

{% comment %} --- Determine pill source --- {% endcomment %}
{% assign use_product_types = false %}
{% assign use_top_level_pills = false %}

{% if is_cross_category %}
  {% comment %} Store-wide collections: show main category pills {% endcomment %}
  {% assign use_top_level_pills = true %}
{% else %}
  {% comment %} Check if product_tag data looks like top-level categories {% endcomment %}
  {% assign tags_that_are_top_level = 0 %}
  {% assign tags_total = 0 %}
  {% for tag in product_tags %}
    {% assign option_tag = tag | strip %}
    {% if option_tag != blank %}
      {% assign tags_total = tags_total | plus: 1 %}
      {% assign option_handle = option_tag | handleize %}
      {% if top_level_categories contains option_handle %}
        {% assign tags_that_are_top_level = tags_that_are_top_level | plus: 1 %}
      {% endif %}
    {% endif %}
  {% endfor %}

  {% if tags_total == 0 %}
    {% assign use_product_types = true %}
  {% elsif tags_that_are_top_level > 0 %}
    {% assign use_product_types = true %}
  {% endif %}
{% endif %}

{% comment %} --- Build the pill tab list --- {% endcomment %}
{% assign pill_items = '' %}

{% if use_top_level_pills %}
  {% comment %} Use the main navigation categories as pills {% endcomment %}
  {% assign pill_items = top_level_labels %}
{% elsif use_product_types %}
  {% comment %} Use collection.all_types to get ALL product types {% endcomment %}
  {% for ptype in collection.all_types %}
    {% assign ptype_stripped = ptype | strip %}
    {% if ptype_stripped != blank %}
      {% if pill_items == '' %}
        {% assign pill_items = ptype_stripped %}
      {% else %}
        {% assign pill_items = pill_items | append: '|||' | append: ptype_stripped %}
      {% endif %}
    {% endif %}
  {% endfor %}
{% else %}
  {% comment %} Use metafield product_tag data {% endcomment %}
  {% assign seen_tags = ',' %}
  {% for tag in product_tags %}
    {% assign option_tag = tag | strip %}
    {% if option_tag != blank %}
      {% assign option_handle = option_tag | handleize %}
      {% capture option_token %},{{ option_handle }},{% endcapture %}
      {% unless seen_tags contains option_token %}
        {% assign seen_tags = seen_tags | append: option_handle | append: ',' %}
        {% if pill_items == '' %}
          {% assign pill_items = option_tag %}
        {% else %}
          {% assign pill_items = pill_items | append: '|||' | append: option_tag %}
        {% endif %}
      {% endunless %}
    {% endif %}
  {% endfor %}
{% endif %}

{% comment %} Split pill_items — top-level uses comma, others use ||| {% endcomment %}
{% if use_top_level_pills %}
  {% assign pill_list = pill_items | split: ',' %}
{% else %}
  {% assign pill_list = pill_items | split: '|||' %}
{% endif %}

{% if current_collection_handle == 'daddy-me'
  or current_collection_handle == 'daddy-me-t-shirts'
  or current_collection_handle == 'trunks'
%}
  {% assign pill_list = 'Daddy & Me T-Shirts|||Trunks' | split: '|||' %}
{% endif %}

{% if current_collection_handle == 'new-women-outfits' or current_collection_handle == 'family-matching-outfits' %}
  {% assign pill_list = 'family-swimsuits|||family-sets|||family-pajamas|||family-tops|||family-sweaters' | split: '|||' %}
{% endif %}

{% comment %} --- Clean up the collection label for pill display (strip common prefixes) --- {% endcomment %}
{% assign pill_display_label = current_collection_label %}
{% assign prefixes_to_strip = 'Mother Daughter ,Mommy and Me ,Matching ,Daddy and Me ,Family Matching ' %}
{% assign prefix_list = prefixes_to_strip | split: ',' %}
{% for prefix in prefix_list %}
  {% assign prefix_stripped = prefix | strip %}
  {% if pill_display_label contains prefix_stripped %}
    {% assign pill_display_label = pill_display_label | remove: prefix_stripped | strip %}
  {% endif %}
{% endfor %}
{% if pill_display_label == blank %}
  {% assign pill_display_label = current_collection_label %}
{% endif %}

{% comment %} --- Check if current collection is in the pill list (only count pills with products) --- {% endcomment %}
{% assign has_alternate_categories = false %}
{% assign current_in_options = false %}
{% for item in pill_list %}
  {% assign item_handle = item | strip | handleize %}
  {% assign target_collection = collections[item_handle] %}
  {% if item_handle == current_collection_handle %}
    {% assign current_in_options = true %}
  {% elsif target_collection != blank and target_collection.all_products_count > 0 %}
    {% assign has_alternate_categories = true %}
  {% endif %}
{% endfor %}

{% if current_collection_handle == 'daddy-me'
  or current_collection_handle == 'new-women-outfits'
  or current_collection_handle == 'family-matching-outfits'
%}
  {% assign current_in_options = true %}
{% endif %}

{% comment %} --- Detect if breadcrumb parent should be hidden --- {% endcomment %}
{% assign hide_parent = false %}
{% assign parent_handle = parent_category | handleize %}
{% if current_collection_handle == parent_handle %}
  {% assign hide_parent = true %}
{% endif %}
{% if is_cross_category %}
  {% assign hide_parent = true %}
{% endif %}
{% if current_collection_handle == 'new-women-outfits' or current_collection_handle == 'family-matching-outfits' %}
  {% assign hide_parent = true %}
{% endif %}

<div class="page-width page-width--collection-breadcrumbs">
  <nav class="breadcrumb collection-breadcrumb" aria-label="breadcrumbs">
    <a href="{{ routes.root_url }}" title="Home" class="collection-breadcrumb__link mobile-hide">Home</a>

    {% unless hide_parent %}
      <span aria-hidden="true" class="collection-breadcrumb__separator mobile-hide">&rsaquo;</span>
      <a href="{{ collections_base_url }}{{ parent_handle }}" class="collection-breadcrumb__link mobile-hide">
        {{ parent_category }}
      </a>
    {% endunless %}

    <span aria-hidden="true" class="collection-breadcrumb__separator mobile-hide">&rsaquo;</span>
    <span class="collection-breadcrumb__current">{{ current_breadcrumb_label }}</span>
  </nav>

  {% if has_alternate_categories %}
    <div class="collection-category-nav" role="navigation" aria-label="Collection categories">
      <div class="collection-category-nav__tabs-wrap">
        <ul class="collection-category-nav__tabs list-unstyled" role="list">
          {% unless current_in_options %}
            <li class="collection-category-nav__item">
              <a href="{{ collection.url }}" class="collection-category-nav__tab is-active" aria-current="page">
                {{ pill_display_label }}
              </a>
            </li>
          {% endunless %}

          {% for item in pill_list %}
            {% assign item_label = item | strip %}
            {% assign item_display_label = item_label %}
            {% assign item_handle = item_label | handleize %}
            {% if item_handle == 'daddy-me-t-shirts' %}
              {% if current_collection_handle == 'daddy-me'
                or current_collection_handle == 'daddy-me-t-shirts'
                or current_collection_handle == 'trunks'
              %}
                {% assign item_display_label = 'T-Shirts' %}
              {% endif %}
            {% endif %}
            {% if current_collection_handle == 'new-women-outfits' or current_collection_handle == 'family-matching-outfits' %}
              {% case item_handle %}
                {% when 'family-swimsuits' %}
                  {% assign item_display_label = 'Swimsuits' %}
                {% when 'family-sets' %}
                  {% assign item_display_label = 'Sets' %}
                {% when 'family-pajamas' %}
                  {% assign item_display_label = 'Pajamas' %}
                {% when 'family-tops' %}
                  {% assign item_display_label = 'Tops' %}
                {% when 'family-sweaters' %}
                  {% assign item_display_label = 'Sweaters & Jackets' %}
              {% endcase %}
            {% endif %}
            {% assign target_collection = collections[item_handle] %}
            {% assign force_show_pill = false %}
            {% if current_collection_handle == 'new-women-outfits' or current_collection_handle == 'family-matching-outfits' %}
              {% if item_handle == 'family-swimsuits'
                or item_handle == 'family-sets'
                or item_handle == 'family-pajamas'
                or item_handle == 'family-tops'
                or item_handle == 'family-sweaters'
              %}
                {% assign force_show_pill = true %}
              {% endif %}
            {% endif %}
            {% comment %} Skip pills that link to missing or empty collections {% endcomment %}
            {% if item_handle != current_collection_handle %}
              {% unless force_show_pill %}
                {% if target_collection == blank %}
                  {% continue %}
                {% endif %}
                {% if target_collection.all_products_count == 0 %}
                  {% continue %}
                {% endif %}
              {% endunless %}
            {% endif %}
            {% assign pill_url = collections_base_url | append: item_handle %}
            {% if target_collection != blank %}
              {% assign pill_url = target_collection.url %}
            {% endif %}
            <li class="collection-category-nav__item">
              <a
                href="{{ pill_url }}"
                class="collection-category-nav__tab{% if item_handle == current_collection_handle %} is-active{% endif %}"
                {% if item_handle == current_collection_handle %}
                  aria-current="page"
                {% endif %}
              >
                {{ item_display_label }}
              </a>
            </li>
          {% endfor %}
        </ul>
      </div>
    </div>
  {% endif %}
</div>
