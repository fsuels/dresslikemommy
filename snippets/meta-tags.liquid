{%- liquid
  assign og_title = page_title | default: shop.name
  assign og_url = canonical_url | default: request.origin
  assign og_type = 'website'
  assign og_description = page_description | default: shop.description | default: shop.name
  assign should_noindex = false
  assign noindex_collection_facets = false

  if request.page_type == 'collection' and collection != blank and collection.handle == 'swimsuits'
    assign og_title = 'Swimsuits'
  endif

  if request.page_type == 'product'
    assign og_type = 'product'
  elsif request.page_type == 'article'
    assign og_type = 'article'
  elsif request.page_type == 'password'
    assign og_url = request.origin
  endif

  if request.page_type == 'search' or request.page_type == 'cart' or request.page_type == '404' or request.page_type == 'password'
    assign should_noindex = true
  endif

  if template contains 'customers/'
    assign should_noindex = true
  endif

  comment
    TSEO-005: Noindex collection pages with tags, filters, or sort params
    to prevent index bloat from faceted navigation variants.
    Indexable: base collection URLs and paginated-only URLs.
  endcomment
  if request.page_type == 'collection'
    if current_tags and current_tags.size > 0
      assign should_noindex = true
      assign noindex_collection_facets = true
    endif
    assign current_url_string = request.url | default: canonical_url | default: ''
    assign current_query_string = request.query_string | default: ''
    if current_url_string contains 'filter.' or current_url_string contains 'sort_by=' or current_query_string contains 'filter.' or current_query_string contains 'sort_by='
      assign should_noindex = true
      assign noindex_collection_facets = true
    endif
  endif
%}

{%- if should_noindex -%}
  <meta name="robots" content="noindex,{% if noindex_collection_facets %} follow{% else %} nofollow{% endif %}">
{%- endif -%}

<meta property="og:site_name" content="{{ shop.name }}">
<meta property="og:url" content="{{ og_url }}">
<meta property="og:title" content="{{ og_title | escape }}">
<meta property="og:type" content="{{ og_type }}">
<meta property="og:description" content="{{ og_description | escape }}">

{%- if page_image -%}
  <meta property="og:image" content="https:{{ page_image | image_url }}">
  <meta property="og:image:secure_url" content="https:{{ page_image | image_url }}">
  <meta property="og:image:width" content="{{ page_image.width }}">
  <meta property="og:image:height" content="{{ page_image.height }}">
{%- endif -%}

{%- if request.page_type == 'product' -%}
  {%- assign product_price_amount = product.price | divided_by: 100.0 -%}
  {%- assign shop_currency_code = shop.currency.iso_code | default: shop.currency | append: '' | strip | upcase | replace: ' ', '' | replace: '$', '' | replace: '.', '' | replace: '-', '' -%}
  {%- assign product_price_currency = cart.currency.iso_code | default: localization.country.currency.iso_code | default: shop_currency_code -%}
  {%- assign product_price_currency = product_price_currency | append: '' | strip | upcase | replace: ' ', '' | replace: '$', '' | replace: '.', '' | replace: '-', '' -%}
  {%- if product_price_currency == blank or product_price_currency.size != 3 -%}
    {%- assign product_price_currency = shop_currency_code -%}
  {%- endif -%}
  {%- if product_price_currency == blank or product_price_currency.size != 3 -%}
    {%- assign product_price_currency = 'USD' -%}
  {%- endif -%}
  <meta property="og:price:amount" content="{{ product_price_amount }}">
  <meta property="product:price:amount" content="{{ product_price_amount }}">
  <meta property="og:price:currency" content="{{ product_price_currency }}">
  <meta property="product:price:currency" content="{{ product_price_currency }}">
{%- endif -%}

{%- liquid
  assign hreflang_origin = shop.url | default: request.origin
  assign hreflang_canonical = canonical_url | default: request.url
  assign hreflang_relative_path = hreflang_canonical | replace_first: hreflang_origin, ''
  if hreflang_relative_path == hreflang_canonical
    assign request_origin_fallback = request.origin | default: ''
    if request_origin_fallback != blank
      assign hreflang_relative_path = hreflang_canonical | replace_first: request_origin_fallback, ''
    endif
  endif
  if hreflang_relative_path == hreflang_canonical
    assign canonical_without_scheme = hreflang_canonical | split: '://' | last
    assign canonical_parts = canonical_without_scheme | split: '/'
    assign canonical_path_parts = canonical_parts | slice: 1, 200
    assign hreflang_relative_path = canonical_path_parts | join: '/'
    assign hreflang_relative_path = '/' | append: hreflang_relative_path
  endif
  assign current_locale_root = request.locale.root_url | default: localization.language.root_url | default: routes.root_url | default: '/'
  assign current_locale_root_with_slash = current_locale_root | append: '/'

  if current_locale_root != '/'
    if hreflang_relative_path == current_locale_root
      assign hreflang_relative_path = '/'
    elsif hreflang_relative_path contains current_locale_root_with_slash
      assign hreflang_relative_path = hreflang_relative_path | remove_first: current_locale_root
    endif
  endif

  if hreflang_relative_path == blank
    assign hreflang_relative_path = '/'
  endif

  assign hreflang_primary_href = hreflang_canonical
-%}

{%- if localization.available_languages and localization.available_languages.size > 0 -%}
  {%- for language in localization.available_languages -%}
    {%- liquid
      assign hreflang_href = hreflang_origin
      assign language_root = language.root_url | default: '/'
      if language_root == '/'
        assign hreflang_href = hreflang_href | append: hreflang_relative_path
      else
        assign hreflang_href = hreflang_href | append: language_root
        if hreflang_relative_path != '/'
          assign hreflang_href = hreflang_href | append: hreflang_relative_path
        endif
      endif
      if language.primary
        assign hreflang_primary_href = hreflang_href
      endif
    -%}
    <link rel="alternate" hreflang="{{ language.iso_code | downcase | escape }}" href="{{ hreflang_href | escape }}">
  {%- endfor -%}
  <link rel="alternate" hreflang="x-default" href="{{ hreflang_primary_href | escape }}">
{%- endif -%}

{%- if settings.social_twitter_link != blank -%}
  <meta name="twitter:site" content="{{ settings.social_twitter_link | split: 'twitter.com/' | last | prepend: '@' }}">
{%- endif -%}
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ og_title | escape }}">
<meta name="twitter:description" content="{{ og_description | escape }}">
