{%- liquid
  assign context = context | default: 'default'
  assign label = label | default: 'Delivery'
  assign processing_min = settings.shipping_processing_days_min | default: 2
  assign processing_max = settings.shipping_processing_days_max | default: processing_min
  assign transit_min = settings.shipping_transit_days_min | default: 7
  assign transit_max = settings.shipping_transit_days_max | default: transit_min
  assign total_min = processing_min | plus: transit_min
  assign total_max = processing_max | plus: transit_max
  assign fallback = 'Processing ' | append: processing_min | append: '-' | append: processing_max | append: ' business days + ' | append: transit_min | append: '-' | append: transit_max | append: ' business days transit'
-%}

<div class="shipping-estimate shipping-estimate--{{ context }}">
  <div class="shipping-estimate__icon" aria-hidden="true">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" role="presentation">
      <path d="M3 7h13v10H3z" stroke="currentColor" stroke-width="1.5" fill="none"/>
      <path d="M16 11h4l2 3v3h-6z" stroke="currentColor" stroke-width="1.5" fill="none"/>
      <circle cx="7" cy="18" r="2" stroke="currentColor" stroke-width="1.5" fill="none"/>
      <circle cx="17" cy="18" r="2" stroke="currentColor" stroke-width="1.5" fill="none"/>
    </svg>
  </div>
  <div class="shipping-estimate__content">
    <p class="shipping-estimate__label">{{ label }}</p>
    <p class="shipping-estimate__value" data-shipping-estimate-text>
      {{ fallback }}
    </p>
    <p class="shipping-estimate__note" data-shipping-holiday-note hidden></p>
  </div>
</div>
