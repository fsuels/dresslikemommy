{%- assign shipping_lines = settings.shipping_promises | to_string | split: "\n" -%}
<ul class="shipping-promise-list">
  {%- assign has_entries = false -%}
  {%- for line in shipping_lines -%}
    {%- assign trimmed = line | strip -%}
    {%- if trimmed != blank -%}
      {%- assign has_entries = true -%}
      {%- assign parts = trimmed | split: ':' -%}
      {%- assign iso = parts[0] | strip | upcase -%}
      {%- assign range = parts[1] | default: '' | strip -%}
      {%- assign range_parts = range | split: '-' -%}
      {%- assign min_days = range_parts[0] | strip | default: settings.shipping_transit_days_min -%}
      {%- assign max_days = range_parts[1] | strip | default: settings.shipping_transit_days_max -%}
      <li><strong>{{ iso }}</strong>: {{ min_days }}–{{ max_days }} business days</li>
    {%- endif -%}
  {%- endfor -%}
  {%- unless has_entries -%}
    <li>{{ settings.shipping_transit_days_min }}–{{ settings.shipping_transit_days_max }} business days worldwide</li>
  {%- endunless -%}
</ul>
