{% assign predictive_search_height = 470 %}
{% assign search_box_width = 400 %}

<div class="EzfyHeaderSearch EzfyHeaderSearch--{{ device }}">
  {%- if settings.predictive_search_enabled -%}
    <predictive-search class="search-modal__form" data-loading-text="{{ 'accessibility.loading' | t }}">
  {%- else -%}
    <search-form class="search-modal__form">
  {%- endif -%}
  <form action="{{ routes.search_url }}" method="get" role="search" class="search search-modal__form">
    <div class="field">
      <input
        class="search__input field__input"
        id="{{ input_id }}"
        type="search"
        name="q"
        value="{{ search.terms | escape }}"
        placeholder="{{ 'general.search.search' | t }}"
        {%- if settings.predictive_search_enabled -%}
          role="combobox"
          aria-expanded="false"
          aria-owns="predictive-search-results"
          aria-controls="predictive-search-results"
          aria-haspopup="listbox"
          aria-autocomplete="list"
          autocorrect="off"
          autocomplete="off"
          autocapitalize="off"
          spellcheck="false"
        {%- endif -%}
      >
      <label class="field__label" for="{{ input_id }}">{{ 'general.search.search' | t }}</label>
      <input type="hidden" name="options[prefix]" value="last">
      <button
        type="reset"
        class="reset__button field__button{% if search.terms == blank %} hidden{% endif %}"
        aria-label="{{ 'general.search.reset' | t }}"
      >
        <svg class="icon icon-close" aria-hidden="true" focusable="false">
          <use xlink:href="#icon-reset">
        </svg>
      </button>
      <button class="search__button field__button" aria-label="{{ 'general.search.search' | t }}">
        <svg class="icon icon-search" aria-hidden="true" focusable="false">
          <use href="#icon-search">
        </svg>
      </button>
    </div>

    {%- if settings.predictive_search_enabled -%}
      <div class="predictive-search predictive-search--header" tabindex="-1" data-predictive-search>
        <div class="predictive-search__loading-state">
          <svg
            aria-hidden="true"
            focusable="false"
            class="spinner"
            viewBox="0 0 66 66"
            xmlns="http://www.w3.org/2000/svg"
          >
            <circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle>
          </svg>
        </div>
      </div>

      <span class="predictive-search-status visually-hidden" role="status" aria-hidden="true"></span>
    {%- endif -%}
  </form>
  {%- if settings.predictive_search_enabled -%}
    </predictive-search>
  {%- else -%}
    </search-form>
  {%- endif -%}
</div>

<style>
/* ========================================
   MOBILE: Hide full-width search bar.
   The search icon in the header (from header-search.liquid)
   opens Shopify's built-in search modal with predictive search.
   ======================================== */
@media (max-width: 990px) {
  /* Hide the old full-width green/pink search bars */
  .EzfyHeaderSearch--mobile,
  .EzfyHeaderSearch--desktop {
    display: none !important;
    margin: 0 !important;
    padding: 0 !important;
    height: 0 !important;
    overflow: hidden !important;
  }

  /* Show the mobile search icon (rendered from header-search.liquid) */
  .mobile-header-search-icon {
    display: flex !important;
    align-items: center;
    order: -1; /* Place it near the hamburger (left side) */
  }
  /* Force the details-modal and header__search to be visible inside our wrapper */
  .mobile-header-search-icon details-modal,
  .mobile-header-search-icon details-modal.header__search,
  .mobile-header-search-icon .header__search {
    display: inline-flex !important;
    line-height: 0;
  }
  .mobile-header-search-icon .header__icon--search {
    display: flex !important;
    align-items: center;
    justify-content: center;
    padding: 0 0.4rem;
  }
  .mobile-header-search-icon .header__icon--search .icon {
    width: 2rem;
    height: 2rem;
  }

  /* Style the search modal to look like a dropdown on mobile */
  .mobile-header-search-icon .search-modal.modal__content {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 999;
    background: #fff;
  }
  .mobile-header-search-icon .search-modal__content {
    padding: 1rem 1.5rem;
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
  }
  .mobile-header-search-icon .search-modal__form,
  .mobile-header-search-icon .search-modal__form > * {
    width: 100% !important;
    max-width: 100% !important;
  }
  .mobile-header-search-icon .search__input {
    height: 44px;
    font-size: 16px;
    border-radius: 8px;
  }
  .mobile-header-search-icon .search-modal__close-button {
    position: absolute;
    top: 1rem;
    right: 1rem;
    z-index: 10;
  }
  .mobile-header-search-icon .predictive-search--header {
    width: 100% !important;
    max-width: 100% !important;
    position: relative;
    top: auto;
    left: auto;
    right: auto;
  }

  body {
    overflow-x: hidden;
  }

  [id] .header {
    display: flex !important;
    flex-wrap: wrap;
    justify-content: space-between;
  }
}

/* Desktop: hide mobile-only elements */
@media (min-width: 991px) {
  .mobile-header-search-icon {
    display: none !important;
  }
  .EzfyHeaderSearch--mobile {
    display: none !important;
    margin: 0;
    padding: 0;
  }
}

/* Desktop search bar (thin pink line) */
.EzfyHeaderSearch--desktop {
  display: block;
  height: 5px;
  background-color: #F7CAC9;
  border-bottom: 1px solid rgba(128,128,128,0.3);
  box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
}

.predictive-search__results-groups-wrapper {
  flex-direction: column !important;
}

.search-modal__form,
.search-modal__form > * {
  width: {{ search_box_width }}px !important;
  max-width: 100% !important;
}

/* Keep header icon hit areas clear */
.EzfyHeaderSearch--desktop > predictive-search.search-modal__form,
.EzfyHeaderSearch--desktop > search-form.search-modal__form {
  pointer-events: none;
}

.EzfyHeaderSearch--desktop > predictive-search.search-modal__form > .search-modal__form,
.EzfyHeaderSearch--desktop > search-form.search-modal__form > .search-modal__form,
.EzfyHeaderSearch--desktop > predictive-search.search-modal__form [data-predictive-search],
.EzfyHeaderSearch--desktop > search-form.search-modal__form [data-predictive-search] {
  pointer-events: auto;
}

.predictive-search {
  max-height: {{ predictive_search_height }}px !important;
}
</style>
