{% comment %}
  Enhanced collection card with overlay label + CTA
{% endcomment %}

{%- liquid
  assign collection_available = false
  if card_collection and card_collection != blank
    assign collection_available = true
  endif
  assign collection_title = 'onboarding.collection_title' | t
  assign collection_url = '#'
  if collection_available and card_collection.title != blank
    assign collection_title = card_collection.title | escape
  endif
  if collection_available
    assign collection_url = card_collection.url
  endif
  assign is_holiday_collection = false
  if collection_available and card_collection.handle contains 'christmas'
    assign is_holiday_collection = true
  endif
  assign ratio = 1
  if card_collection.featured_image and media_aspect_ratio == 'portrait'
    assign ratio = 0.8
  elsif card_collection.featured_image and media_aspect_ratio == 'adapt'
    assign ratio = card_collection.featured_image.aspect_ratio
  endif
  if ratio == 0 or ratio == null
    assign ratio = 1
  endif
-%}

<div class="collection-card-wrapper">
  <a
    class="collection-card-link"{% unless collection_available %} role="link" aria-disabled="true"{% endunless %}
    href="{{ collection_url }}"
    style="--ratio-percent: {{ 1 | divided_by: ratio | times: 100 }}%;"
  >
    <div class="collection-card__media">
      {%- if card_collection.featured_image -%}
        <img
          srcset="
            {%- if card_collection.featured_image.width >= 165 -%}{{ card_collection.featured_image | image_url: width: 165 }} 165w,{%- endif -%}
            {%- if card_collection.featured_image.width >= 330 -%}{{ card_collection.featured_image | image_url: width: 330 }} 330w,{%- endif -%}
            {%- if card_collection.featured_image.width >= 535 -%}{{ card_collection.featured_image | image_url: width: 535 }} 535w,{%- endif -%}
            {%- if card_collection.featured_image.width >= 750 -%}{{ card_collection.featured_image | image_url: width: 750 }} 750w,{%- endif -%}
            {%- if card_collection.featured_image.width >= 1000 -%}{{ card_collection.featured_image | image_url: width: 1000 }} 1000w,{%- endif -%}
            {%- if card_collection.featured_image.width >= 1500 -%}{{ card_collection.featured_image | image_url: width: 1500 }} 1500w,{%- endif -%}
            {{ card_collection.featured_image | image_url }} {{ card_collection.featured_image.width }}w
          "
          src="{{ card_collection.featured_image | image_url: width: 1200 }}"
          sizes="
            (min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 | divided_by: columns }}px,
            (min-width: 750px) {% if columns > 1 %}calc((100vw - 8rem) / 2){% else %}calc(100vw - 8rem){% endif %},
            calc(100vw - 3rem)
          "
          alt="{{ card_collection.featured_image.alt | default: collection_title }}"
          height="{{ card_collection.featured_image.height }}"
          width="{{ card_collection.featured_image.width }}"
          loading="lazy"
          class="collection-card__image motion-reduce"
        >
      {%- else -%}
        <div class="collection-card__placeholder">
          {{ placeholder_image | placeholder_svg_tag: 'placeholder-svg' }}
        </div>
      {%- endif -%}

      <span class="collection-card__label">{{ collection_title }}</span>

      {%- if is_holiday_collection -%}
        <span class="collection-card__badge">Holiday</span>
      {%- endif -%}

      <span class="collection-card__cta" aria-hidden="true">
        <span class="button button--secondary">Shop {{ collection_title }}</span>
      </span>
    </div>
  </a>
</div>
